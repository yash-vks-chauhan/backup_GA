<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.VIBRATE" />
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-feature android:name="android.hardware.camera" android:required="false" />

    <queries>
        <intent>
            <action android:name="android.speech.RecognitionService" />
        </intent>
        <!-- So the home wordmark can deep-link the follow tap into the Instagram app
             (Android 11+ package visibility); falls back to the browser if absent. -->
        <package android:name="com.instagram.android" />
    </queries>

    <application
        android:name=".GrideeApplication"
        android:allowBackup="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Gridee"
        android:usesCleartextTraffic="false"
        android:networkSecurityConfig="@xml/network_security_config"
        tools:targetApi="36">

        <!-- Google Mobile Ads (AdMob) App ID -->
        <meta-data
            android:name="com.google.android.gms.ads.APPLICATION_ID"
            android:value="ca-app-pub-5268197817154713~4357463233" />
        
        <!-- Razorpay public key fallback (used if server doesn't supply keyId) -->
        <meta-data
            android:name="com.razorpay.ApiKey"
            android:value="@string/razorpay_key_id" />

        <meta-data
            android:name="com.google.firebase.messaging.default_notification_channel_id"
            android:value="gridee_updates" />

        <service
            android:name=".notifications.GrideeFirebaseMessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>

        <receiver
            android:name=".notifications.BookingActiveNotificationReceiver"
            android:exported="false" />


        
        <activity
            android:name=".ui.auth.SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.Gridee.LaunchSplash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".ui.maintenance.MaintenanceActivity"
            android:exported="false"
            android:theme="@style/Theme.Gridee.NoActionBar" />

        <activity
            android:name=".ui.auth.WelcomeActivity"
            android:exported="false"
            android:theme="@style/Theme.Gridee.PostSplashLaunch" />

        <activity
            android:name=".ui.auth.LoginActivity"
            android:exported="false"
            android:theme="@style/Theme.Gridee.NoActionBar" />

        <activity
            android:name=".ui.auth.JwtTestActivity"
            android:exported="false"
            android:theme="@style/Theme.Gridee.NoActionBar" />
        
        <activity
            android:name=".ui.auth.RegistrationActivity"
            android:exported="false"
            android:theme="@style/Theme.Gridee.NoActionBar" />

        <activity
            android:name=".ui.auth.ForgotPasswordActivity"
            android:exported="false"
            android:theme="@style/Theme.Gridee.NoActionBar" />

        <activity
            android:name=".ui.auth.EmailVerificationActivity"
            android:exported="false"
            android:theme="@style/Theme.Gridee.NoActionBar" />

        <activity
            android:name=".ui.auth.AddVehicleActivity"
            android:exported="false"
            android:theme="@style/Theme.Gridee.NoActionBar" />

        <activity
            android:name=".ui.auth.AddPhoneActivity"
            android:exported="false"
            android:theme="@style/Theme.Gridee.NoActionBar" />
        
        <activity
            android:name=".ui.MainComposeActivity"
            android:exported="false"
            android:theme="@style/Theme.Gridee.NoActionBar">
            <!-- Uncomment these lines to make this the main activity -->
            <!--
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            -->
        </activity>
        
        <activity
            android:name=".ui.compose.EdgeToEdgeComposeActivity"
            android:exported="false"
            android:theme="@style/Theme.Gridee.NoActionBar" />
        
        <activity
            android:name=".ui.demo.EdgeToEdgeDemoActivity"
            android:exported="false"
            android:theme="@style/Theme.Gridee.NoActionBar">
            <!-- Test activity - can be made launcher for testing -->
            <!--
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            -->
        </activity>
        
        <activity
            android:name=".ui.main.MainContainerActivity"
            android:exported="false"
            android:configChanges="uiMode"
            android:theme="@style/Theme.Gridee.MainLaunch" />
        
        <activity
            android:name=".ui.operator.OperatorDashboardActivity"
            android:exported="false"
            android:label="Operator Dashboard"
            android:theme="@style/Theme.Gridee.PostSplashLaunch" />

        <activity
            android:name=".ui.operator.OperatorMenuActivity"
            android:exported="false"
            android:theme="@style/Theme.Gridee.NoActionBar" />

        <activity
            android:name=".ui.wallet.WalletTopUpActivity"
            android:exported="false"
            android:theme="@style/Theme.Gridee.NoActionBar" />

        <activity
            android:name=".ui.wallet.WalletAddMoneyActivity"
            android:exported="false"
            android:theme="@style/Theme.Gridee.NoActionBar"
            android:windowSoftInputMode="adjustResize" />
            
        <activity
            android:name=".ui.activities.TransactionHistoryActivity"
            android:exported="false"
            android:theme="@style/Theme.Gridee.NoActionBar" />
        
        <activity
            android:name=".ui.discovery.ParkingDiscoveryActivity"
            android:exported="false"
            android:theme="@style/Theme.Gridee.NoActionBar" />
        
        <activity
            android:name=".ui.details.ParkingDetailsActivity"
            android:exported="false"
            android:theme="@style/Theme.Gridee.NoActionBar" />
        
        <activity
            android:name=".ui.booking.BookingFlowActivity"
            android:exported="false"
            android:theme="@style/Theme.Gridee.NoActionBar" />
        
        <activity
            android:name=".ui.booking.ParkingLotSelectionActivity"
            android:exported="false"
            android:theme="@style/Theme.Gridee.NoActionBar" />
        
        <activity
            android:name=".ui.booking.ParkingSpotSelectionActivity"
            android:exported="false"
            android:theme="@style/Theme.Gridee.NoActionBar" />
        
        <activity
            android:name=".ui.booking.PaymentActivity"
            android:exported="false"
            android:theme="@style/Theme.Gridee.NoActionBar" />
        
        <activity
            android:name=".ui.booking.BookingConfirmationActivity"
            android:exported="false"
            android:theme="@style/Theme.Gridee.NoActionBar" />

        <activity
            android:name=".ui.bookings.BookingDetailsActivity"
            android:exported="false"
            android:theme="@style/Theme.Gridee.NoActionBar" />
        
        <activity
            android:name=".ui.profile.EditProfileActivity"
            android:exported="false"
            android:theme="@style/Theme.Gridee.NoActionBar" />
        
        <activity
            android:name=".ui.profile.PrivacySettingsActivity"
            android:exported="false"
            android:theme="@style/Theme.Gridee.NoActionBar" />

        <activity
            android:name=".ui.profile.NotificationsActivity"
            android:exported="false"
            android:theme="@style/Theme.Gridee.NoActionBar" />

        <activity
            android:name=".ui.profile.BookingHistoryPlaceholderActivity"
            android:exported="false"
            android:theme="@style/Theme.Gridee.NoActionBar" />

        <activity
            android:name=".ui.profile.AccountSettingsActivity"
            android:exported="false"
            android:theme="@style/Theme.Gridee.NoActionBar" />

        <activity
            android:name=".ui.profile.DisplayThemeActivity"
            android:exported="false"
            android:configChanges="uiMode"
            android:theme="@style/Theme.Gridee.NoActionBar" />

        <activity
            android:name=".ui.profile.HelpSupportActivity"
            android:exported="false"
            android:theme="@style/Theme.Gridee.NoActionBar" />

        <activity
            android:name=".ui.profile.SupportTicketChatActivity"
            android:exported="false"
            android:theme="@style/Theme.Gridee.NoActionBar"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".ui.profile.NewSupportRequestActivity"
            android:exported="false"
            android:theme="@style/Theme.Gridee.NoActionBar"
            android:windowSoftInputMode="adjustResize" />
        
        <activity
            android:name=".ui.wallet.WalletActivity"
            android:exported="false"
            android:theme="@style/Theme.Gridee.NoActionBar" />

        <activity
            android:name=".ui.qr.QrScannerActivity"
            android:exported="false"
            android:theme="@style/Theme.Gridee.NoActionBar" />

        <activity
            android:name="com.journeyapps.barcodescanner.CaptureActivity"
            tools:remove="android:screenOrientation" />

    </application>

</manifest>
