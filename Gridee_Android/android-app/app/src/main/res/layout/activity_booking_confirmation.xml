<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_primary"
    android:fitsSystemWindows="false">

    <!-- Scrollable content. Padded top and bottom by the header/footer
         heights so the first and last items sit clear of the frosted chrome. -->
    <ScrollView
        android:id="@+id/contentScroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:clipToPadding="false"
        android:scrollbars="none"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="92dp"
            android:paddingBottom="180dp">

            <!-- Hero: success check + title. The check sits where the morph-
                 reveal green contracts to, so the incoming motion lands on
                 this view exactly. -->
            <LinearLayout
                android:id="@+id/heroBlock"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:paddingHorizontal="24dp"
                android:paddingBottom="28dp">

                <ImageView
                    android:id="@+id/ivSuccessCheck"
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:src="@drawable/avd_booking_success"
                    android:importantForAccessibility="no" />

                <TextView
                    android:id="@+id/tvTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:text="Booking Confirmed"
                    android:textColor="@color/text_primary"
                    android:textSize="26sp"
                    android:fontFamily="@font/inter_bold"
                    android:letterSpacing="-0.01"
                    android:textAlignment="center"
                    android:alpha="0"
                    android:translationY="24dp" />

                <TextView
                    android:id="@+id/tvSubtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Your spot is reserved"
                    android:textColor="@color/text_secondary"
                    android:textSize="15sp"
                    android:fontFamily="@font/inter_medium"
                    android:textAlignment="center"
                    android:alpha="0"
                    android:translationY="24dp" />
            </LinearLayout>

            <!-- The ticket: a single card that holds the booking summary.
                 Solid hairline dividers (no dashed lines) and generous padding
                 keep it on-brand with the rest of the app's cards. -->
            <androidx.cardview.widget.CardView
                android:id="@+id/ticketCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:alpha="0"
                android:translationY="24dp"
                app:cardBackgroundColor="@color/background_secondary"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="22dp"
                    android:paddingTop="22dp"
                    android:paddingBottom="22dp">

                    <!-- Parking name + address: the hero of the ticket -->
                    <TextView
                        android:id="@+id/tvParkingSpotName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Parking Name"
                        android:textColor="@color/text_primary"
                        android:textSize="22sp"
                        android:fontFamily="@font/inter_bold"
                        android:letterSpacing="-0.01"
                        android:lineSpacingMultiplier="1.05" />

                    <TextView
                        android:id="@+id/tvParkingAddress"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Address"
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp"
                        android:fontFamily="@font/inter_medium" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="20dp"
                        android:background="@color/divider" />

                    <!-- Spot + Vehicle rows -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Spot"
                            android:textColor="@color/text_secondary"
                            android:textSize="14sp"
                            android:fontFamily="@font/inter_medium" />

                        <TextView
                            android:id="@+id/tvSelectedSpot"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="--"
                            android:textColor="@color/text_primary"
                            android:textSize="15sp"
                            android:fontFamily="@font/inter_semibold" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/rowVehicle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Vehicle"
                            android:textColor="@color/text_secondary"
                            android:textSize="14sp"
                            android:fontFamily="@font/inter_medium" />

                        <TextView
                            android:id="@+id/tvVehicleNumber"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="--"
                            android:textColor="@color/text_primary"
                            android:textSize="15sp"
                            android:fontFamily="@font/inter_semibold" />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="20dp"
                        android:background="@color/divider" />

                    <!-- Date / Time / Duration rows -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Date"
                            android:textColor="@color/text_secondary"
                            android:textSize="14sp"
                            android:fontFamily="@font/inter_medium" />

                        <TextView
                            android:id="@+id/tvParkingDate"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="--"
                            android:textColor="@color/text_primary"
                            android:textSize="15sp"
                            android:fontFamily="@font/inter_semibold" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Time"
                            android:textColor="@color/text_secondary"
                            android:textSize="14sp"
                            android:fontFamily="@font/inter_medium" />

                        <TextView
                            android:id="@+id/tvStartTime"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="--"
                            android:textColor="@color/text_primary"
                            android:textSize="15sp"
                            android:fontFamily="@font/inter_semibold" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Duration"
                            android:textColor="@color/text_secondary"
                            android:textSize="14sp"
                            android:fontFamily="@font/inter_medium" />

                        <TextView
                            android:id="@+id/tvDuration"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="--"
                            android:textColor="@color/text_primary"
                            android:textSize="15sp"
                            android:fontFamily="@font/inter_semibold" />
                    </LinearLayout>

                    <!-- End time still bound by activity code, kept hidden -->
                    <TextView
                        android:id="@+id/tvEndTime"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:visibility="gone"
                        tools:text="End Time"/>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="20dp"
                        android:background="@color/divider" />

                    <!-- Payment block: total amount on a confident row of its
                         own, then the payment-method line below. No status
                         badge — "Paid" reads in green inline. -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:baselineAligned="false">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Total"
                            android:textColor="@color/text_secondary"
                            android:textSize="14sp"
                            android:fontFamily="@font/inter_medium" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:baselineAligned="false">

                            <TextView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:background="@drawable/bg_gridee_coin_dark"
                                android:text="G"
                                android:textColor="@color/btn_text_on_brand"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:fontFamily="@font/inter_bold"
                                android:gravity="center"
                                android:includeFontPadding="false"
                                android:paddingTop="1dp"
                                android:layout_marginEnd="8dp" />

                            <TextView
                                android:id="@+id/tvTotalAmount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0.00"
                                android:textColor="@color/text_primary"
                                android:textSize="22sp"
                                android:fontFamily="@font/inter_bold" />
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:id="@+id/tvPaymentMethod"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Wallet"
                            android:textColor="@color/text_secondary"
                            android:textSize="13sp"
                            android:fontFamily="@font/inter_medium" />

                        <TextView
                            android:id="@+id/tvPaymentStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Paid"
                            android:textColor="@color/success_green"
                            android:textSize="13sp"
                            android:fontFamily="@font/inter_bold" />
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Reference card: secondary, lighter weight than the main ticket.
                 Sits below as supporting info so the main ticket stays the
                 focal point of the page. -->
            <androidx.cardview.widget.CardView
                android:id="@+id/referenceCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="12dp"
                android:alpha="0"
                android:translationY="24dp"
                app:cardBackgroundColor="@color/background_secondary"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="22dp"
                    android:paddingTop="18dp"
                    android:paddingBottom="18dp">

                    <TextView
                        android:id="@+id/tvBookingId"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Booking ID: --"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif-monospace" />

                    <TextView
                        android:id="@+id/tvTransactionId"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="3dp"
                        android:text="Transaction ID: --"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif-monospace" />

                    <TextView
                        android:id="@+id/tvBookingTime"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Booked just now"
                        android:textColor="@color/text_tertiary"
                        android:textSize="11sp"
                        android:fontFamily="@font/inter_regular" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

    <!-- ── Top frosted chrome ───────────────────────────────────────
         Gradient backdrop that fades to transparent as content scrolls
         under it. Matches the convention used on booking details, history,
         and profile screens. -->
    <View
        android:id="@+id/headerFrost"
        android:layout_width="match_parent"
        android:layout_height="96dp"
        android:background="@drawable/bg_toolbar_frosted"
        android:importantForAccessibility="no"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="20dp"
        android:paddingTop="14dp"
        android:paddingBottom="10dp"
        app:layout_constraintTop_toTopOf="parent">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btnBack"
            style="@style/Widget.Gridee.BackButton.IOS26"
            android:layout_width="@dimen/ios26_back_button_size"
            android:layout_height="@dimen/ios26_back_button_size"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <ImageView
                android:layout_width="@dimen/ios26_back_icon_size"
                android:layout_height="@dimen/ios26_back_icon_size"
                android:layout_gravity="center"
                android:contentDescription="@string/back"
                android:src="@drawable/ic_close"
                app:tint="@color/brand_primary" />
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/tvHeaderTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Confirmation"
            android:textColor="@color/text_primary"
            android:textSize="17sp"
            android:fontFamily="@font/inter_bold"
            android:letterSpacing="-0.01"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- ── Bottom frosted chrome + footer actions ───────────────────
         The frosted backdrop lets the ticket scroll beneath the footer
         gracefully instead of slamming into a hard panel edge. -->
    <View
        android:id="@+id/footerFrost"
        android:layout_width="match_parent"
        android:layout_height="160dp"
        android:background="@drawable/bg_bottom_frosted"
        android:importantForAccessibility="no"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- Notification anchor above footer -->
    <FrameLayout
        android:id="@+id/notificationAnchor"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:paddingBottom="8dp"
        app:layout_constraintBottom_toTopOf="@id/actionButtons"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <LinearLayout
        android:id="@+id/actionButtons"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="8dp"
        android:paddingBottom="20dp"
        android:alpha="0"
        android:translationY="24dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnViewBooking"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="View Booking"
            android:textColor="@color/md3_on_primary"
            android:textAllCaps="false"
            android:textSize="16sp"
            android:fontFamily="@font/inter_bold"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:stateListAnimator="@null"
            app:backgroundTint="@color/brand_primary"
            app:cornerRadius="28dp"
            app:elevation="0dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnShareReceipt"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="Share Receipt"
                android:textColor="@color/text_primary"
                android:textAllCaps="false"
                android:textSize="14sp"
                android:fontFamily="@font/inter_semibold"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:stateListAnimator="@null"
                app:cornerRadius="22dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDone"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="Done"
                android:textColor="@color/text_primary"
                android:textAllCaps="false"
                android:textSize="14sp"
                android:fontFamily="@font/inter_semibold"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:stateListAnimator="@null"
                app:cornerRadius="22dp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Reveal overlay: carries the morph button's success color across the
         activity boundary. The entrance animator contracts it into the
         success-check icon at the top of the page. -->
    <View
        android:id="@+id/revealOverlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@color/confirm_btn_success_bg"
        android:visibility="gone"
        android:importantForAccessibility="no"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
