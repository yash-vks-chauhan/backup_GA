<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true"
    android:paddingHorizontal="24dp"
    android:paddingTop="20dp">

    <!-- Left Icon Container -->
    <FrameLayout
        android:id="@+id/container_icon"
        android:layout_width="52dp"
        android:layout_height="52dp"
        android:background="@drawable/bg_icon_rounded_square_white"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/iv_icon"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_booking_history_ticket"
            app:tint="#6B7280" />

    </FrameLayout>

    <!-- Content Section -->
    <LinearLayout
        android:id="@+id/layout_content"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="12dp"
        android:orientation="vertical"
        android:gravity="center_vertical"
        app:layout_constraintEnd_toStartOf="@+id/layout_status_pill"
        app:layout_constraintStart_toEndOf="@id/container_icon"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Spot Name -->
        <TextView
            android:id="@+id/tv_parking_spot"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:fontFamily="@font/inter_bold"
            android:maxLines="1"
            android:text="Spot A-15"
            android:textColor="#111827"
            android:textSize="16sp"
            android:textStyle="bold" />

        <!-- Date -->
        <TextView
            android:id="@+id/tv_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:fontFamily="@font/inter_medium"
            android:text="Oct 10, 2025"
            android:textColor="#6B7280"
            android:textSize="14sp" />

        <!-- Price -->
        <TextView
            android:id="@+id/tv_price"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:fontFamily="@font/inter_bold"
            android:text="₹150"
            android:textColor="#111827"
            android:textSize="14sp" />

    </LinearLayout>

    <!-- Status Pill (Right) -->
    <LinearLayout
        android:id="@+id/layout_status_pill"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/status_soft_completed"
        android:gravity="center"
        android:paddingHorizontal="12dp"
        android:paddingVertical="6dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/tv_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/inter_bold"
            android:text="Completed"
            android:textColor="#374151"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Bottom Spacer for padding consistency -->
    <!-- Constrained to content to ensure full height -->
    <View
        android:id="@+id/view_spacer"
        android:layout_width="match_parent"
        android:layout_height="20dp"
        app:layout_constraintBottom_toTopOf="@id/divider_line"
        app:layout_constraintTop_toBottomOf="@id/layout_content"/>

    <!-- Bottom Divider -->
    <!-- Apple-style: 0.5dp hairline, #C6C6C8 separator color -->
    <View
        android:id="@+id/divider_line"
        android:layout_width="0dp"
        android:layout_height="1px"
        android:background="#C6C6C8"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="@id/container_icon"
        android:layout_marginTop="0dp" />

</androidx.constraintlayout.widget.ConstraintLayout>
