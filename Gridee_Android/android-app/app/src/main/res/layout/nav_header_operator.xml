<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/white"
    android:padding="24dp"
    android:theme="@style/ThemeOverlay.AppCompat.Light">

    <!-- Branding -->
    <TextView
        android:id="@+id/tv_brand_logo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Gridee"
        android:textSize="22sp"
        android:textColor="#111827"
        android:fontFamily="@font/inter_bold"
        android:letterSpacing="-0.02"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Profile Row container (Clickable) -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layout_profile_section"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true"
        android:paddingVertical="8dp"
        app:layout_constraintTop_toBottomOf="@id/tv_brand_logo"
        app:layout_constraintStart_toStartOf="parent">

        <!-- Avatar -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_avatar"
            android:layout_width="48dp"
            android:layout_height="48dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="#E5E7EB"
            app:cardBackgroundColor="#F3F4F6"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_profile_enhanced"
                app:tint="#6B7280"
                android:contentDescription="Avatar" />

        </com.google.android.material.card.MaterialCardView>

        <!-- Status Badge -->
        <View
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:background="@drawable/circle_status_active"
            android:backgroundTint="#10B981"
            android:elevation="2dp"
            app:layout_constraintBottom_toBottomOf="@id/card_avatar"
            app:layout_constraintEnd_toEndOf="@id/card_avatar"
            android:layout_marginEnd="2dp"
            android:layout_marginBottom="2dp" />

        <!-- Name & Subtitle -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="8dp"
            app:layout_constraintStart_toEndOf="@id/card_avatar"
            app:layout_constraintEnd_toStartOf="@id/iv_chevron"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <TextView
                android:id="@+id/tv_header_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Operator Account"
                android:textColor="#111827"
                android:textSize="16sp"
                android:fontFamily="@font/inter_bold" />

            <TextView
                android:id="@+id/tv_header_subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="View Profile"
                android:textColor="#6B7280"
                android:textSize="13sp"
                android:fontFamily="@font/inter_medium" />
        </LinearLayout>

        <!-- Chevron -->
        <ImageView
            android:id="@+id/iv_chevron"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@drawable/ic_chevron_right"
            app:tint="#D1D5DB"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
