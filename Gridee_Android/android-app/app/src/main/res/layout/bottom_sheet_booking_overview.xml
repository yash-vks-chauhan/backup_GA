<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@android:color/transparent"
    android:paddingTop="0dp"
    android:paddingBottom="28dp">

    <!-- Handle Bar -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="6dp">

        <ImageButton
            android:id="@+id/buttonCloseSheet"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_gravity="end"
            android:background="@drawable/booking_sheet_close_background"
            android:contentDescription="@string/close"
            android:foreground="@drawable/ripple_close_button"
            android:padding="10dp"
            android:src="@drawable/ic_close"
            android:tint="@color/booking_sheet_icon_tint" />

    </FrameLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:paddingHorizontal="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardBookingSummary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="12dp"
                android:clipToPadding="false"
                android:clipChildren="false"
                app:cardBackgroundColor="@color/background_secondary"
                app:cardCornerRadius="30dp"
                app:cardElevation="0dp"
                android:elevation="0dp"
                app:strokeColor="@color/booking_card_border_default"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="24dp"
                    android:paddingTop="42dp"
                    android:paddingBottom="42dp">

                    <!-- Header Row: Spot Name + Status -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:id="@+id/textLocationName"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Spot A-15"
                            android:textColor="@color/text_primary"
                            android:textSize="26sp"
                            android:maxLines="1"
                            android:ellipsize="end"
                            app:autoSizeTextType="uniform"
                            app:autoSizeMaxTextSize="26sp"
                            app:autoSizeMinTextSize="16sp"
                            android:layout_marginEnd="16dp"
                            android:textStyle="bold"
                            android:fontFamily="@font/inter_medium" />

                        <!-- Status Chip matching item_booking.xml style -->
                        <TextView
                            android:id="@+id/textStatusChip"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/status_soft_active"
                            android:paddingHorizontal="14dp"
                            android:paddingVertical="8dp"
                            android:text="Active"
                            android:textColor="@color/booking_status_active_text"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/inter_medium"/>
                    </LinearLayout>

                    <!-- Sub-header Row: Location Name + Address -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:layout_marginBottom="48dp">
                        
                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ic_location"
                            android:layout_marginEnd="8dp"
                            app:tint="@color/booking_sheet_secondary_text"/>

                        <TextView
                            android:id="@+id/textSpotName"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Phoenix Marketcity"
                            android:textColor="@color/booking_sheet_secondary_text"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:maxLines="1"
                            android:ellipsize="end"
                            android:fontFamily="@font/inter_medium" />

                    </LinearLayout>
                    
                    <!-- Stub views for removed badges to prevent binding crash (visibility gone) -->
                     <TextView android:id="@+id/textLocationInitial" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
                     <FrameLayout android:id="@+id/locationBadgeContainer" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>

                    <!-- Hero Time Section -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="start|center_vertical"
                        android:layout_marginBottom="32dp">

                        <TextView
                            android:id="@+id/textCheckIn"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="10:00 AM"
                            android:textSize="24sp"
                            android:maxLines="1"
                            android:textColor="@color/text_primary"
                            android:textStyle="bold"
                            android:fontFamily="@font/inter_medium"
                            android:letterSpacing="-0.03"/>

                        <ImageView
                            android:layout_width="26dp"
                            android:layout_height="26dp"
                            android:src="@drawable/ic_arrow_right"
                            app:tint="@color/text_tertiary"
                            android:layout_marginHorizontal="16dp" />

                        <TextView
                            android:id="@+id/textCheckOut"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="12:00 PM"
                            android:textSize="24sp"
                            android:maxLines="1"
                            android:textColor="@color/text_primary"
                            android:textStyle="bold"
                            android:fontFamily="@font/inter_medium"
                            android:letterSpacing="-0.03"/>
                    </LinearLayout>

                    <!-- Info Pills Row: Vehicle + Duration -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="40dp">

                        <!-- Vehicle Pill -->
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:background="@drawable/bg_pill_gray_f5"
                            android:backgroundTint="@color/gray_50"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="8dp">

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@drawable/ic_car_outlined"
                                app:tint="@color/text_secondary"
                                android:layout_marginEnd="8dp" />

                            <TextView
                                android:id="@+id/textVehicleNumber"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="MH 12 AB 3456"
                                android:textSize="16sp"
                                android:textColor="@color/text_secondary"
                                android:fontFamily="@font/inter_medium" />
                        </LinearLayout>

                        <Space
                            android:layout_width="12dp"
                            android:layout_height="wrap_content" />

                        <!-- Duration Pill -->
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:background="@drawable/bg_pill_gray_f5"
                            android:backgroundTint="@color/gray_50"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="8dp">

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@drawable/ic_time"
                                app:tint="@color/text_secondary"
                                android:layout_marginEnd="8dp" />

                            <TextView
                                android:id="@+id/textDuration"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="2h 15m"
                                android:textSize="16sp"
                                android:textColor="@color/text_secondary"
                                android:fontFamily="@font/inter_medium" />
                        </LinearLayout>

                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginBottom="20dp"
                        android:background="@color/booking_sheet_divider" />

                    <!-- Vertical Details Stack (Minus ID) -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <!-- Booking Date Row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingVertical="14dp">
                            
                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@drawable/ic_calendar_today"
                                android:tint="@color/booking_sheet_secondary_text"
                                android:layout_marginEnd="12dp"/>
                            
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Booking Date"
                                android:textSize="16sp"
                                android:textColor="@color/booking_sheet_secondary_text"
                                android:fontFamily="@font/inter_regular"/>

                            <Space
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"/>
                            
                            <TextView
                                android:id="@+id/textBookingDate"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Oct 10, 2025"
                                android:textSize="16sp"
                                android:textColor="@color/text_primary"
                                android:textStyle="bold"
                                android:fontFamily="@font/inter_medium"/>
                        </LinearLayout>
                        
                        <!-- Amount Row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingVertical="14dp">

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@drawable/ic_amount_paid"
                                android:tint="@color/booking_sheet_secondary_text"
                                android:layout_marginEnd="12dp"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Amount Paid"
                                android:textSize="16sp"
                                android:textColor="@color/booking_sheet_secondary_text"
                                android:fontFamily="@font/inter_regular"/>

                            <Space
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"/>

                            <TextView
                                android:id="@+id/textAmount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="₹150.00"
                                android:textSize="18sp"
                                android:textColor="@color/text_primary"
                                android:textStyle="bold"
                                android:fontFamily="@font/inter_medium"/>
                        </LinearLayout>

                    </LinearLayout>
                    
                    <LinearLayout
                        android:id="@+id/actionRow"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="48dp"
                        android:orientation="vertical">


                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/actionCancel"
                            style="@style/Widget.Material3.Button.UnelevatedButton"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:minHeight="54dp"
                            android:text="@string/cancel_booking"
                            android:textAllCaps="false"
                            android:textColor="@color/status_text_cancelled"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            app:backgroundTint="@color/cancel_button_bg"
                            app:cornerRadius="28dp"
                            app:icon="@drawable/ic_close"
                            app:iconGravity="textStart"
                            app:iconSize="18dp"
                            app:iconTint="@color/status_text_cancelled" />

                    </LinearLayout>
                    
                    <!-- Discrete Footer Booking ID -->
                    <TextView
                        android:id="@+id/textBookingId"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginTop="24dp"
                        android:text="ID: #BK001"
                        android:textColor="@color/booking_sheet_secondary_text"
                        android:textSize="12sp"
                        android:background="@drawable/bg_pill_gray_f5"
                        android:backgroundTint="@color/gray_200"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="4dp"
                        android:fontFamily="@font/inter_medium"/>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </ScrollView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnExtendBooking"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="8dp"
        android:text="@string/extend_booking"
        android:textAllCaps="false"
        android:textStyle="bold"
        android:visibility="gone"
        app:cornerRadius="16dp"
        style="@style/Widget.Material3.Button.TonalButton" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/buttonScanQr"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        android:text="@string/scan_to_check_in"
        android:textAllCaps="false"
        android:textStyle="bold"
        android:insetTop="12dp"
        android:insetBottom="12dp"
        app:cornerRadius="16dp" />

</LinearLayout>
