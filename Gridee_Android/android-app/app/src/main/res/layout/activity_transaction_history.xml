<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_primary"
    android:fitsSystemWindows="true"
    tools:context=".ui.activities.TransactionHistoryActivity">

    <!-- Transactions List — full-bleed, scrolls behind the transparent header -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_all_transactions"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="100dp"
        android:paddingHorizontal="16dp"
        tools:listitem="@layout/item_transaction" />

    <!-- Empty State -->
    <LinearLayout
        android:id="@+id/layout_empty_state"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone"
        android:padding="32dp">

        <ImageView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@drawable/ic_history"
            android:alpha="0.3"
            android:layout_marginBottom="16dp"
            app:tint="@color/text_primary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No Transactions"
            android:textSize="18sp"
            android:textStyle="bold"
            android:fontFamily="@font/inter_bold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="You haven't made any transactions yet."
            android:textSize="14sp"
            android:fontFamily="@font/inter_medium"
            android:gravity="center" />
    </LinearLayout>

    <!-- Loading -->
    <ProgressBar
        android:id="@+id/progress_bar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone"
        android:indeterminateTint="@color/primary" />

    <!-- Unified frosted header overlay — gradient from opaque at top to transparent at bottom.
         Same pattern as profile page. Covers header + dissolve zone below. -->
    <View
        android:id="@+id/view_toolbar_frost"
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:layout_gravity="top"
        android:background="@drawable/bg_toolbar_frosted"
        android:alpha="0" />

    <!-- Header content — floats on top of everything -->
    <LinearLayout
        android:id="@+id/layout_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:orientation="vertical"
        android:paddingTop="8dp">

        <!-- Top Row: Back button + Title + Count -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="20dp"
            android:paddingBottom="8dp">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btn_back"
                style="@style/Widget.Gridee.BackButton.IOS26"
                android:layout_width="@dimen/ios26_back_button_size"
                android:layout_height="@dimen/ios26_back_button_size"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent">

                <ImageView
                    android:layout_width="@dimen/ios26_back_icon_size"
                    android:layout_height="@dimen/ios26_back_icon_size"
                    android:layout_gravity="center"
                    android:contentDescription="@string/back"
                    android:src="@drawable/ic_arrow_back"
                    app:tint="@color/brand_primary" />
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/tv_header_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="History"
                android:textColor="@color/text_primary"
                android:textSize="20sp"
                android:textStyle="bold"
                android:fontFamily="@font/inter_bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />

            <TextView
                android:id="@+id/tv_transaction_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Loading..."
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:fontFamily="@font/inter_medium"
                android:visibility="gone"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                tools:visibility="visible"
                tools:text="12" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Filter Row -->
        <HorizontalScrollView
            android:id="@+id/filter_scroll_view"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:overScrollMode="never"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:clipToPadding="false"
            android:clipChildren="false"
            android:layout_marginTop="4dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingVertical="8dp"
                android:clipChildren="false"
                android:clipToPadding="false">

                <!-- Date Filter Chip -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btn_filter_date"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="12dp"
                    app:cardCornerRadius="100dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="@color/white"
                    app:strokeWidth="0.8dp"
                    app:strokeColor="@color/filter_chip_stroke"
                    android:stateListAnimator="@null"
                    android:clickable="true"
                    android:focusable="true">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="10dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Date"
                            android:textColor="@color/text_primary"
                            android:textSize="13sp"
                            android:fontFamily="@font/inter_bold"
                            android:layout_marginEnd="6dp"/>

                        <ImageView
                            android:id="@+id/iv_arrow_date"
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:src="@drawable/ic_arrow_down"
                            app:tint="@color/text_secondary" />

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Amount Filter Chip -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btn_filter_amount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="12dp"
                    app:cardCornerRadius="100dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="@color/white"
                    app:strokeWidth="0.8dp"
                    app:strokeColor="@color/filter_chip_stroke"
                    android:stateListAnimator="@null"
                    android:clickable="true"
                    android:focusable="true">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="10dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Amount"
                            android:textColor="@color/text_primary"
                            android:textSize="13sp"
                            android:fontFamily="@font/inter_bold"
                            android:layout_marginEnd="6dp"/>

                        <ImageView
                            android:id="@+id/iv_arrow_amount"
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:src="@drawable/ic_arrow_down"
                            app:tint="@color/text_secondary" />

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Type Filter Chip -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btn_filter_payment_method"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="12dp"
                    app:cardCornerRadius="100dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="@color/white"
                    app:strokeWidth="0.8dp"
                    app:strokeColor="@color/filter_chip_stroke"
                    android:stateListAnimator="@null"
                    android:clickable="true"
                    android:focusable="true">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="10dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Type"
                            android:textColor="@color/text_primary"
                            android:textSize="13sp"
                            android:fontFamily="@font/inter_bold"
                            android:layout_marginEnd="6dp"/>

                        <ImageView
                            android:id="@+id/iv_arrow_payment"
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:src="@drawable/ic_arrow_down"
                            app:tint="@color/text_secondary" />

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>
        </HorizontalScrollView>

        <!-- Dynamic Section Subtitle — fades in on scroll, shows current date section -->
        <TextView
            android:id="@+id/tv_section_subtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:alpha="0"
            android:fontFamily="@font/inter_bold"
            android:gravity="center"
            android:paddingTop="4dp"
            android:paddingBottom="10dp"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            tools:alpha="1"
            tools:text="Today" />

    </LinearLayout>

    <!-- OVERLAYS (Must be last to be on top) -->
    <View
        android:id="@+id/modal_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#80000000"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true"
        android:alpha="0"
        android:elevation="10dp" />

    <!-- Date Filter Modal -->
    <LinearLayout
        android:id="@+id/date_filter_modal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_bottom_sheet_universal"
        android:visibility="gone"
        android:translationY="500dp"
        android:layout_gravity="bottom"
        android:elevation="20dp"
        android:clickable="true"
        android:focusable="true">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="32dp">

            <View
                android:id="@+id/handle_date"
                android:layout_width="32dp"
                android:layout_height="4dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/handle_pill_minimal"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <ImageView
                android:id="@+id/btn_close_date"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginTop="20dp"
                android:layout_marginEnd="20dp"
                android:background="@drawable/bg_close_circle"
                android:src="@drawable/ic_close"
                android:padding="9dp"
                app:tint="@color/text_secondary"
                android:clickable="true"
                android:focusable="true"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:elevation="10dp"/>

            <TextView
                android:id="@+id/title_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Date Range"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginStart="24dp"
                android:layout_marginTop="24dp"
                app:layout_constraintTop_toBottomOf="@id/handle_date"
                app:layout_constraintStart_toStartOf="parent" />

            <RadioGroup
                android:id="@+id/rg_date_filter"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="16dp"
                app:layout_constraintTop_toBottomOf="@id/title_date">

                <RadioButton
                    android:id="@+id/rb_this_month"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:background="@drawable/selector_pill_white_to_black"
                    android:text="This Month"
                    android:textSize="15sp"
                    android:paddingHorizontal="20dp"
                    android:fontFamily="@font/inter_bold"
                    android:textColor="@color/selector_text_black_to_white"
                    android:button="@null"
                    android:layout_marginTop="8dp"/>

                <RadioButton
                    android:id="@+id/rb_last_30_days"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:background="@drawable/selector_pill_white_to_black"
                    android:text="Last 30 Days"
                    android:textSize="15sp"
                    android:paddingHorizontal="20dp"
                    android:fontFamily="@font/inter_bold"
                    android:textColor="@color/selector_text_black_to_white"
                    android:button="@null"
                    android:layout_marginTop="12dp"/>

                <RadioButton
                    android:id="@+id/rb_last_90_days"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:background="@drawable/selector_pill_white_to_black"
                    android:text="Last 90 Days"
                    android:textSize="15sp"
                    android:paddingHorizontal="20dp"
                    android:fontFamily="@font/inter_bold"
                    android:textColor="@color/selector_text_black_to_white"
                    android:button="@null"
                    android:layout_marginTop="12dp"/>
            </RadioGroup>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="32dp"
                app:layout_constraintTop_toBottomOf="@id/rg_date_filter">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_clear_date_filter"
                    android:layout_width="0dp"
                    android:layout_height="62dp"
                    android:layout_weight="1"
                    android:text="Clear All"
                    android:textColor="@color/text_primary"
                    app:backgroundTint="#F3F4F6"
                    app:cornerRadius="31dp"
                    android:textAllCaps="false"
                    android:fontFamily="@font/inter_bold"
                    android:textSize="15sp"
                    app:elevation="0dp"
                    android:layout_marginEnd="12dp"
                    style="@style/Widget.MaterialComponents.Button.UnelevatedButton"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_apply_date_filter"
                    android:layout_width="0dp"
                    android:layout_height="62dp"
                    android:layout_weight="1"
                    android:text="Apply"
                    android:textColor="@color/white"
                    app:backgroundTint="@color/brand_primary"
                    app:cornerRadius="31dp"
                    android:textAllCaps="false"
                    android:fontFamily="@font/inter_bold"
                    android:textSize="15sp"
                    app:elevation="8dp"
                    app:rippleColor="#33FFFFFF"
                    style="@style/Widget.MaterialComponents.Button.UnelevatedButton"/>

            </LinearLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </LinearLayout>

    <!-- Amount Filter Modal -->
    <LinearLayout
        android:id="@+id/amount_filter_modal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_bottom_sheet_universal"
        android:visibility="gone"
        android:translationY="500dp"
        android:layout_gravity="bottom"
        android:elevation="20dp"
        android:clickable="true"
        android:focusable="true">

          <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="32dp">

            <View
                android:id="@+id/handle_amount"
                android:layout_width="32dp"
                android:layout_height="4dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/handle_pill_minimal"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

             <ImageView
                android:id="@+id/btn_close_amount"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_close"
                android:padding="8dp"
                app:tint="@color/text_secondary"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="12dp"
                android:layout_marginEnd="16dp" />

            <TextView
                android:id="@+id/title_amount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Filter Amount"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginStart="24dp"
                android:layout_marginTop="24dp"
                app:layout_constraintTop_toBottomOf="@id/handle_amount"
                app:layout_constraintStart_toStartOf="parent" />

             <View
                android:layout_width="match_parent"
                android:layout_height="300dp"
                android:background="@color/background_primary"
                android:layout_marginTop="20dp"
                android:layout_marginHorizontal="24dp"
                app:layout_constraintTop_toBottomOf="@id/title_amount" />
        </androidx.constraintlayout.widget.ConstraintLayout>
    </LinearLayout>

    <!-- Payment Filter Modal -->
    <LinearLayout
        android:id="@+id/payment_filter_modal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_bottom_sheet_universal"
        android:visibility="gone"
        android:translationY="500dp"
        android:layout_gravity="bottom"
        android:elevation="20dp"
        android:clickable="true"
        android:focusable="true">

          <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="32dp">

            <View
                android:id="@+id/handle_payment"
                android:layout_width="32dp"
                android:layout_height="4dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/handle_pill_minimal"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <ImageView
                android:id="@+id/btn_close_payment"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_close"
                android:padding="8dp"
                app:tint="@color/text_secondary"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="12dp"
                android:layout_marginEnd="16dp" />

            <TextView
                android:id="@+id/title_payment"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Payment Method"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginStart="24dp"
                android:layout_marginTop="24dp"
                app:layout_constraintTop_toBottomOf="@id/handle_payment"
                app:layout_constraintStart_toStartOf="parent" />

            <View
                android:layout_width="match_parent"
                android:layout_height="300dp"
                android:background="@color/background_primary"
                android:layout_marginTop="20dp"
                android:layout_marginHorizontal="24dp"
                app:layout_constraintTop_toBottomOf="@id/title_payment" />
        </androidx.constraintlayout.widget.ConstraintLayout>
    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
