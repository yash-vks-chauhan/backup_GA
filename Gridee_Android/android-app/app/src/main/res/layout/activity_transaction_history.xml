<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_primary"
    android:fitsSystemWindows="true"
    tools:context=".ui.activities.TransactionHistoryActivity">

    <!-- Professional, Minimal Header - Centered Title -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layout_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="20dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        app:layout_constraintTop_toTopOf="parent">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btn_back"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:clickable="true"
            android:focusable="true"
            app:cardCornerRadius="22dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/border_light"
            app:strokeWidth="1dp"
            app:cardBackgroundColor="@color/white"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_arrow_back"
                app:tint="@color/text_primary" />
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/tv_header_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="History"
            android:textColor="@color/text_primary"
            android:textSize="20sp"
            android:textStyle="bold"
            android:fontFamily="@font/inter_bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <TextView
            android:id="@+id/tv_transaction_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Loading..."
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:fontFamily="@font/inter_medium"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            tools:visibility="visible"
            tools:text="12" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Filter Row - Refined Style -->
    <HorizontalScrollView
        android:id="@+id/filter_scroll_view"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:overScrollMode="never"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:clipToPadding="false"
        android:clipChildren="false"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="12dp"
        app:layout_constraintTop_toBottomOf="@id/layout_header">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingVertical="16dp"
            android:clipChildren="false"
            android:clipToPadding="false">

            <!-- Date Filter Chip -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btn_filter_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="12dp"
                app:cardCornerRadius="100dp"
                app:cardElevation="12dp"
                app:cardBackgroundColor="@android:color/transparent"
                app:strokeWidth="0dp"
                app:strokeColor="@android:color/transparent"
                android:outlineSpotShadowColor="#590F172A"
                android:outlineAmbientShadowColor="#1F0F172A"
                android:stateListAnimator="@animator/wallet_chip_state_animator"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_wallet_chip_ceramic"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="20dp"
                    android:paddingVertical="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Date"
                        android:textColor="#111827"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/inter_bold"
                        android:layout_marginEnd="8dp"/>

                    <ImageView
                        android:id="@+id/iv_arrow_date"
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:src="@drawable/ic_arrow_down"
                        app:tint="#6B7280" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Amount Filter Chip -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btn_filter_amount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="12dp"
                app:cardCornerRadius="100dp"
                app:cardElevation="12dp"
                app:cardBackgroundColor="@android:color/transparent"
                app:strokeWidth="0dp"
                app:strokeColor="@android:color/transparent"
                android:outlineSpotShadowColor="#590F172A"
                android:outlineAmbientShadowColor="#1F0F172A"
                android:stateListAnimator="@animator/wallet_chip_state_animator"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_wallet_chip_ceramic"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="20dp"
                    android:paddingVertical="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Amount"
                        android:textColor="#111827"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/inter_bold"
                        android:layout_marginEnd="8dp"/>

                    <ImageView
                        android:id="@+id/iv_arrow_amount"
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:src="@drawable/ic_arrow_down"
                        app:tint="#6B7280" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Payment Method Filter Chip -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btn_filter_payment_method"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="12dp"
                app:cardCornerRadius="100dp"
                app:cardElevation="12dp"
                app:cardBackgroundColor="@android:color/transparent"
                app:strokeWidth="0dp"
                app:strokeColor="@android:color/transparent"
                android:outlineSpotShadowColor="#590F172A"
                android:outlineAmbientShadowColor="#1F0F172A"
                android:stateListAnimator="@animator/wallet_chip_state_animator"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_wallet_chip_ceramic"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="20dp"
                    android:paddingVertical="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Type"
                        android:textColor="#111827"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/inter_bold"
                        android:layout_marginEnd="8dp"/>

                    <ImageView
                        android:id="@+id/iv_arrow_payment"
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:src="@drawable/ic_arrow_down"
                        app:tint="#6B7280" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </HorizontalScrollView>

    <!-- Transactions List -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_all_transactions"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingTop="4dp"
        android:paddingBottom="100dp"
        android:paddingHorizontal="16dp"
        app:layout_constraintTop_toBottomOf="@id/filter_scroll_view"
        app:layout_constraintBottom_toBottomOf="parent"
        tools:listitem="@layout/item_transaction" />

    <!-- Empty State -->
    <LinearLayout
        android:id="@+id/layout_empty_state"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/filter_scroll_view"
        app:layout_constraintBottom_toBottomOf="parent"
        android:padding="32dp">

        <ImageView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@drawable/ic_history"
            android:alpha="0.3"
            android:layout_marginBottom="16dp"
            app:tint="@color/text_primary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No Transactions"
            android:textSize="18sp"
            android:textStyle="bold"
            android:fontFamily="@font/inter_bold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="You haven't made any transactions yet."
            android:textSize="14sp"
            android:fontFamily="@font/inter_medium"
            android:gravity="center" />
    </LinearLayout>

    <!-- Loading -->
    <ProgressBar
        android:id="@+id/progress_bar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:indeterminateTint="@color/primary"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- OVERLAYS (Must be last to be on top) -->
    <View
        android:id="@+id/modal_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#80000000"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true"
        android:alpha="0"
        android:elevation="10dp" />

    <!-- Date Filter Modal -->
    <LinearLayout
        android:id="@+id/date_filter_modal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_bottom_sheet_universal"
        android:visibility="gone"
        android:translationY="500dp"
        app:layout_constraintBottom_toBottomOf="parent"
        android:elevation="20dp"
        android:clickable="true"
        android:focusable="true">
        
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="32dp">

            <View
                android:id="@+id/handle_date"
                android:layout_width="32dp"
                android:layout_height="4dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/handle_pill_minimal"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <ImageView
                android:id="@+id/btn_close_date"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_close"
                android:padding="8dp"
                app:tint="@color/text_secondary"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="12dp"
                android:layout_marginEnd="16dp" />

            <TextView
                android:id="@+id/title_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Date Range"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginStart="24dp"
                android:layout_marginTop="24dp"
                app:layout_constraintTop_toBottomOf="@id/handle_date"
                app:layout_constraintStart_toStartOf="parent" />

            <RadioGroup
                android:id="@+id/rg_date_filter"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="16dp"
                app:layout_constraintTop_toBottomOf="@id/title_date">

                <RadioButton
                    android:id="@+id/rb_this_month"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="This Month"
                    android:textSize="16sp"
                    android:paddingVertical="12dp"
                    android:fontFamily="@font/inter_medium"
                    android:textColor="@color/text_primary"
                    android:buttonTint="@color/brand_primary"
                    android:layoutDirection="rtl"
                    android:layout_marginTop="8dp"/>

                <RadioButton
                    android:id="@+id/rb_last_30_days"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Last 30 Days"
                    android:textSize="16sp"
                    android:paddingVertical="12dp"
                    android:fontFamily="@font/inter_medium"
                    android:textColor="@color/text_primary"
                    android:buttonTint="@color/brand_primary"
                    android:layoutDirection="rtl"/>

                <RadioButton
                    android:id="@+id/rb_last_90_days"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Last 90 Days"
                    android:textSize="16sp"
                    android:paddingVertical="12dp"
                    android:fontFamily="@font/inter_medium"
                    android:textColor="@color/text_primary"
                    android:buttonTint="@color/brand_primary"
                    android:layoutDirection="rtl"/>
            </RadioGroup>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="32dp"
                app:layout_constraintTop_toBottomOf="@id/rg_date_filter">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_clear_date_filter"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:text="Clear All"
                    android:textColor="@color/text_primary"
                    app:backgroundTint="@color/background_secondary"
                    app:cornerRadius="12dp"
                    android:textAllCaps="false"
                    android:fontFamily="@font/inter_bold"
                    android:textSize="16sp"
                    app:elevation="0dp"
                    android:layout_marginEnd="12dp"
                    style="@style/Widget.MaterialComponents.Button.UnelevatedButton"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_apply_date_filter"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:text="Apply"
                    android:textColor="@color/white"
                    app:backgroundTint="@color/brand_primary"
                    app:cornerRadius="12dp"
                    android:textAllCaps="false"
                    android:fontFamily="@font/inter_bold"
                    android:textSize="16sp"
                    app:elevation="0dp"
                    style="@style/Widget.MaterialComponents.Button.UnelevatedButton"/>

            </LinearLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </LinearLayout>

    <!-- Amount Filter Modal -->
    <LinearLayout
        android:id="@+id/amount_filter_modal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_bottom_sheet_universal"
        android:visibility="gone"
        android:translationY="500dp"
        app:layout_constraintBottom_toBottomOf="parent"
        android:elevation="20dp"
        android:clickable="true"
        android:focusable="true">
        
          <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="32dp">

            <View
                android:id="@+id/handle_amount"
                android:layout_width="32dp"
                android:layout_height="4dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/handle_pill_minimal"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

             <ImageView
                android:id="@+id/btn_close_amount"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_close"
                android:padding="8dp"
                app:tint="@color/text_secondary"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="12dp"
                android:layout_marginEnd="16dp" />

            <TextView
                android:id="@+id/title_amount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Filter Amount"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginStart="24dp"
                android:layout_marginTop="24dp"
                app:layout_constraintTop_toBottomOf="@id/handle_amount"
                app:layout_constraintStart_toStartOf="parent" />

             <View
                android:layout_width="match_parent"
                android:layout_height="300dp"
                android:background="@color/background_primary"
                android:layout_marginTop="20dp"
                android:layout_marginHorizontal="24dp"
                app:layout_constraintTop_toBottomOf="@id/title_amount" />
        </androidx.constraintlayout.widget.ConstraintLayout>
    </LinearLayout>

    <!-- Payment Filter Modal -->
    <LinearLayout
        android:id="@+id/payment_filter_modal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_bottom_sheet_universal"
        android:visibility="gone"
        android:translationY="500dp"
        app:layout_constraintBottom_toBottomOf="parent"
        android:elevation="20dp"
        android:clickable="true"
        android:focusable="true">
        
          <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="32dp">

            <View
                android:id="@+id/handle_payment"
                android:layout_width="32dp"
                android:layout_height="4dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/handle_pill_minimal"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <ImageView
                android:id="@+id/btn_close_payment"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_close"
                android:padding="8dp"
                app:tint="@color/text_secondary"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="12dp"
                android:layout_marginEnd="16dp" />

            <TextView
                android:id="@+id/title_payment"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Payment Method"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginStart="24dp"
                android:layout_marginTop="24dp"
                app:layout_constraintTop_toBottomOf="@id/handle_payment"
                app:layout_constraintStart_toStartOf="parent" />

            <View
                android:layout_width="match_parent"
                android:layout_height="300dp"
                android:background="@color/background_primary"
                android:layout_marginTop="20dp"
                android:layout_marginHorizontal="24dp"
                app:layout_constraintTop_toBottomOf="@id/title_payment" />
        </androidx.constraintlayout.widget.ConstraintLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
