<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootContainer"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_bottom_sheet_universal"
    android:clipChildren="false"
    android:clipToPadding="false">

    <!-- ═══════════════════════════════════════════════════════ -->
    <!-- PAGE 1: Vehicle Options                                -->
    <!-- ═══════════════════════════════════════════════════════ -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layoutOptionsPage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="16dp">

        <!-- Drag Handle -->
        <View
            android:id="@+id/dragHandle"
            android:layout_width="32dp"
            android:layout_height="4dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/handle_pill_minimal"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Close Button -->
        <ImageView
            android:id="@+id/btnClose"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginTop="20dp"
            android:layout_marginEnd="20dp"
            android:background="@drawable/bg_close_circle"
            android:src="@drawable/ic_close"
            android:padding="9dp"
            app:tint="@color/text_secondary"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="Close"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            android:elevation="10dp" />

        <!-- Title -->
        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="24dp"
            android:layout_marginEnd="24dp"
            android:text="Vehicle Options"
            android:textColor="@color/text_primary"
            android:textSize="24sp"
            android:textStyle="bold"
            android:fontFamily="@font/inter_bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/dragHandle" />

        <!-- Subtitle -->
        <TextView
            android:id="@+id/tvSubtitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="24dp"
            android:text="Manage your vehicle settings"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:fontFamily="@font/inter_medium"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvTitle" />

        <!-- Actions Container -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="vertical"
            app:layout_constraintTop_toBottomOf="@id/tvSubtitle">

            <!-- Edit Action -->
            <LinearLayout
                android:id="@+id/btnEdit"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:paddingStart="24dp"
                android:paddingTop="16dp"
                android:paddingEnd="24dp"
                android:paddingBottom="16dp">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_edit_profile"
                    app:tint="@color/text_primary" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_weight="1"
                    android:text="Edit Vehicle"
                    android:textColor="@color/text_primary"
                    android:textSize="17sp"
                    android:fontFamily="@font/inter_medium" />

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_arrow_right"
                    app:tint="#E0E0E0" />
            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginStart="64dp"
                android:background="@color/gray_200" />

            <!-- Make Default Action -->
            <LinearLayout
                android:id="@+id/btnMakeDefault"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:paddingStart="24dp"
                android:paddingTop="16dp"
                android:paddingEnd="24dp"
                android:paddingBottom="16dp">

                <ImageView
                    android:id="@+id/ivDefaultIcon"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_vehicle_default"
                    app:tint="@color/text_primary" />

                <TextView
                    android:id="@+id/tvDefaultText"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_weight="1"
                    android:text="Make Default"
                    android:textColor="@color/text_primary"
                    android:textSize="17sp"
                    android:fontFamily="@font/inter_medium" />
                 
                 <!-- This checkmark will only appear if it IS default -->
                 <ImageView
                    android:id="@+id/ivDefaultCheck"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_check_circle"
                    app:tint="@color/status_text_active"
                    android:visibility="gone" />

            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginStart="64dp"
                android:background="@color/gray_200" />

            <!-- Delete Action -->
            <LinearLayout
                android:id="@+id/btnDelete"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:paddingStart="24dp"
                android:paddingTop="16dp"
                android:paddingEnd="24dp"
                android:paddingBottom="16dp">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_delete"
                    app:tint="#D32F2F" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_weight="1"
                    android:text="Delete Vehicle"
                    android:textColor="#D32F2F"
                    android:textSize="17sp"
                    android:fontFamily="@font/inter_medium" />

            </LinearLayout>

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- ═══════════════════════════════════════════════════════ -->
    <!-- PAGE 2: Edit Vehicle (slides in from right)            -->
    <!-- ═══════════════════════════════════════════════════════ -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layoutEditPage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_bottom_sheet_universal"
        android:visibility="gone"
        android:paddingBottom="16dp">

        <!-- Drag Handle (consistency with options page) -->
        <View
            android:id="@+id/editDragHandle"
            android:layout_width="32dp"
            android:layout_height="4dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/handle_pill_minimal"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Back Button (top-left, navigates back to options) -->
        <ImageView
            android:id="@+id/btnEditBack"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginStart="20dp"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_close_circle"
            android:padding="9dp"
            android:src="@drawable/ic_arrow_back"
            app:tint="@color/text_secondary"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="Back"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            android:elevation="10dp" />

        <!-- Edit Title -->
        <TextView
            android:id="@+id/tvEditTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="24dp"
            android:layout_marginEnd="24dp"
            android:text="Edit Vehicle"
            android:textColor="@color/text_primary"
            android:textSize="22sp"
            android:fontFamily="@font/inter_bold"
            android:gravity="center"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/editDragHandle" />

        <!-- Edit Subtitle -->
        <TextView
            android:id="@+id/tvEditSubtitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="24dp"
            android:text="Update it using a valid Indian registration number"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:fontFamily="@font/inter_medium"
            android:gravity="center"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvEditTitle" />

        <!-- Vehicle Number Input -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilVehicleNumber"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="32dp"
            android:layout_marginEnd="24dp"
            android:hint="Vehicle registration number"
            app:boxBackgroundColor="@color/background_secondary"
            app:boxCornerRadiusBottomEnd="28dp"
            app:boxCornerRadiusBottomStart="28dp"
            app:boxCornerRadiusTopEnd="28dp"
            app:boxCornerRadiusTopStart="28dp"
            app:boxStrokeColor="@color/divider"
            app:boxStrokeWidth="1dp"
            app:hintTextColor="@color/text_tertiary"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvEditSubtitle">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etVehicleNumber"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:inputType="textCapCharacters"
                android:maxLength="16"
                android:maxLines="1"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:fontFamily="@font/inter_medium" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Save Changes Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSave"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_marginStart="24dp"
            android:layout_marginTop="24dp"
            android:layout_marginEnd="24dp"
            android:backgroundTint="@color/brand_primary"
            android:fontFamily="@font/inter_bold"
            android:text="Save Changes"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:stateListAnimator="@null"
            app:cornerRadius="30dp"
            app:elevation="0dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tilVehicleNumber" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- ═══════════════════════════════════════════════════════ -->
    <!-- PAGE 3: Delete Vehicle Confirmation (slides in)        -->
    <!-- ═══════════════════════════════════════════════════════ -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layoutDeletePage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_bottom_sheet_universal"
        android:visibility="gone"
        android:paddingBottom="16dp"
        android:clipChildren="false"
        android:clipToPadding="false">

        <!-- Drag Handle -->
        <View
            android:id="@+id/deleteDragHandle"
            android:layout_width="32dp"
            android:layout_height="4dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/handle_pill_minimal"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Back Button (top-left, navigates back to options) -->
        <ImageView
            android:id="@+id/btnDeleteBack"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginStart="20dp"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_close_circle"
            android:padding="9dp"
            android:src="@drawable/ic_arrow_back"
            app:tint="@color/text_secondary"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="Back"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            android:elevation="10dp" />

        <!-- Delete Icon -->
        <FrameLayout
            android:id="@+id/deleteIconFrame"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_marginTop="32dp"
            android:background="@drawable/bg_close_circle"
            app:layout_constraintTop_toBottomOf="@id/deleteDragHandle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:elevation="0dp">

            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_delete"
                app:tint="@color/status_text_cancelled"
                android:padding="2dp" />
        </FrameLayout>

        <!-- Title -->
        <TextView
            android:id="@+id/tvDeleteTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"
            android:layout_marginTop="20dp"
            android:fontFamily="@font/inter_bold"
            android:gravity="center"
            android:text="Delete Vehicle"
            android:textColor="@color/text_primary"
            android:textSize="22sp"
            app:layout_constraintTop_toBottomOf="@id/deleteIconFrame"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Message -->
        <TextView
            android:id="@+id/tvDeleteMessage"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="32dp"
            android:layout_marginTop="12dp"
            android:layout_marginEnd="32dp"
            android:fontFamily="@font/inter_regular"
            android:gravity="center"
            android:lineSpacingExtra="4dp"
            android:text="Are you sure you want to remove this vehicle?"
            android:textColor="@color/text_secondary"
            android:textSize="15sp"
            app:layout_constraintTop_toBottomOf="@id/tvDeleteTitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Actions -->
        <LinearLayout
            android:id="@+id/layoutDeleteActions"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="32dp"
            android:layout_marginEnd="24dp"
            android:gravity="center"
            android:orientation="horizontal"
            app:layout_constraintTop_toBottomOf="@id/tvDeleteMessage"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDeleteCancel"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:backgroundTint="@color/gray_200"
                android:fontFamily="@font/inter_bold"
                android:text="@string/cancel"
                android:textAllCaps="false"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                app:cornerRadius="30dp"
                app:elevation="0dp"
                android:stateListAnimator="@null" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDeleteConfirm"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:backgroundTint="@color/status_text_cancelled"
                android:fontFamily="@font/inter_bold"
                android:text="Delete"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                app:cornerRadius="30dp"
                app:elevation="0dp"
                android:stateListAnimator="@null" />

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</FrameLayout>
