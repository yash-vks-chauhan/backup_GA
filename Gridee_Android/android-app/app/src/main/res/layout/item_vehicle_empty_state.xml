<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_vehicle_item"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:padding="24dp">

    <FrameLayout
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:background="@drawable/bg_vehicle_empty_icon">

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_gravity="center"
            android:contentDescription="@null"
            android:src="@drawable/ic_car_outlined"
            android:tint="@color/icon_secondary" />
    </FrameLayout>

    <TextView
        android:id="@+id/tv_vehicle_state_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:fontFamily="@font/inter_semibold"
        android:text="@string/profile_vehicle_empty_title"
        android:textColor="@color/text_primary"
        android:textSize="15sp" />

    <TextView
        android:id="@+id/tv_vehicle_state_message"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:fontFamily="@font/inter_regular"
        android:gravity="center"
        android:text="@string/profile_vehicle_empty_message"
        android:textColor="@color/text_secondary"
        android:textSize="13sp" />

    <LinearLayout
        android:id="@+id/btn_empty_add_vehicle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:background="@drawable/bg_vehicle_empty_action"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?attr/selectableItemBackground"
        android:gravity="center"
        android:minHeight="40dp"
        android:orientation="horizontal"
        android:paddingStart="18dp"
        android:paddingTop="10dp"
        android:paddingEnd="18dp"
        android:paddingBottom="10dp">

        <ImageView
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:contentDescription="@null"
            android:src="@drawable/ic_add_circle_outline"
            android:tint="@color/text_primary" />

        <TextView
            android:id="@+id/tv_vehicle_state_action"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:fontFamily="@font/inter_medium"
            android:text="@string/profile_vehicle_add_action"
            android:textColor="@color/text_primary"
            android:textSize="14sp" />
    </LinearLayout>

</LinearLayout>
