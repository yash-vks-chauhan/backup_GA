<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="false"
    tools:openDrawer="start">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/main_content"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#F5F5F5"
        android:clipChildren="false"
        android:clipToPadding="false">

        <!-- Header Row -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/header_row"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="8dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:paddingHorizontal="24dp"
            android:clipChildren="false"
            android:clipToPadding="false">

            <!-- Menu Button (Profile Initials) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/button_menu"
                android:layout_width="46dp"
                android:layout_height="46dp"
                app:cardBackgroundColor="#4CAF50"
                app:cardCornerRadius="23dp"
                app:cardElevation="6dp"
                android:elevation="6dp"
                android:outlineSpotShadowColor="#33000000"
                android:outlineAmbientShadowColor="#1A000000"
                tools:targetApi="p"
                app:strokeWidth="1.5dp"
                app:strokeColor="#FFFFFF"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:id="@+id/tv_header_initials"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="O"
                    android:textColor="#FFFFFF"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:fontFamily="@font/inter_bold" />

            </com.google.android.material.card.MaterialCardView>

            <!-- Centered Title -->
            <TextView
                android:id="@+id/text_header_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="@string/op_scanner_tab"
                android:textColor="#111827"
                android:textSize="22sp"
                android:textStyle="bold"
                android:fontFamily="@font/inter_bold"
                android:gravity="center"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toEndOf="@id/button_menu"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginEnd="46dp" /> 
                <!-- marginEnd matches button width to perfectly center -->

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- CONTENT: SCANNER PAGE -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/layout_content_scanner"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layout_constraintTop_toBottomOf="@id/header_row"
            app:layout_constraintBottom_toTopOf="@id/bottom_navigation_container"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- Segmented Control (iOS Style Track) -->
            <FrameLayout
                android:id="@+id/segmented_control_container"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_marginTop="24dp"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                android:background="@drawable/bg_segment_track"
                android:padding="4dp"
                android:clipToPadding="false"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <!-- Sliding Indicator (White Pill) -->
                <View
                    android:id="@+id/segment_slider"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:visibility="invisible"
                    android:background="@drawable/bg_segment_slider"
                    android:elevation="2dp" />

                <LinearLayout
                    android:id="@+id/segment_group"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:elevation="4dp">

                    <!-- Check-In Segment -->
                    <LinearLayout
                        android:id="@+id/segment_checkin"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:background="?attr/selectableItemBackgroundBorderless">

                        <TextView
                            android:id="@+id/text_checkin"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/op_check_in"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/inter_bold"
                            android:textColor="@color/segment_text_unselected" />

                    </LinearLayout>

                    <!-- Check-Out Segment -->
                    <LinearLayout
                        android:id="@+id/segment_checkout"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:background="?attr/selectableItemBackgroundBorderless">

                        <TextView
                            android:id="@+id/text_checkout"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/op_check_out"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/inter_bold"
                            android:textColor="@color/segment_text_unselected" />

                    </LinearLayout>

                </LinearLayout>

            </FrameLayout>

            <!-- Content Area with Pull-to-Refresh -->
            <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
                android:id="@+id/swipe_refresh"
                android:layout_width="0dp"
                android:layout_height="0dp"
                app:layout_constraintTop_toBottomOf="@id/segmented_control_container"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <androidx.core.widget.NestedScrollView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:fillViewport="true"
                    android:clipToPadding="false"
                    android:scrollbars="none"
                    android:paddingTop="16dp"
                    android:paddingBottom="16dp"
                    android:paddingHorizontal="16dp">

                    <!-- Single Action Card -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/card_action"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:cardBackgroundColor="@color/white"
                        app:cardCornerRadius="28dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="0dp">

                        <!-- Container for both modes -->
                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">

                            <!-- SCAN MODE (Default) -->
                            <LinearLayout
                                android:id="@+id/layout_scan_mode"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:gravity="center"
                                android:padding="40dp"
                                android:visibility="visible">

                                <!-- Circular Scan Button -->
                                <com.google.android.material.card.MaterialCardView
                                    android:id="@+id/btn_scan_circular"
                                    android:layout_width="120dp"
                                    android:layout_height="120dp"
                                    app:cardBackgroundColor="#111827"
                                    app:cardCornerRadius="60dp"
                                    app:cardElevation="8dp"
                                    android:clickable="true"
                                    android:focusable="true"
                                    android:foreground="?attr/selectableItemBackground">

                                    <ImageView
                                        android:layout_width="48dp"
                                        android:layout_height="48dp"
                                        android:layout_gravity="center"
                                        android:src="@drawable/ic_camera"
                                        android:tint="@android:color/white"
                                        android:contentDescription="Scan vehicle" />
                                </com.google.android.material.card.MaterialCardView>

                                <!-- Label -->
                                <TextView
                                    android:id="@+id/tv_scan_label"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="24dp"
                                    android:text="@string/op_tap_to_scan"
                                    android:textSize="16sp"
                                    android:textStyle="bold"
                                    android:textColor="@color/text_primary"
                                    android:fontFamily="sans-serif-medium" />
                                    
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="4dp"
                                    android:text="Align QR code within frame"
                                    android:textSize="14sp"
                                    android:textColor="@color/text_secondary"
                                    android:fontFamily="sans-serif" />

                                <!-- Manual Entry Link -->
                                <com.google.android.material.button.MaterialButton
                                    android:id="@+id/link_manual_entry"
                                    style="@style/Widget.MaterialComponents.Button.TextButton"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="32dp"
                                    android:text="@string/op_manual_entry_label"
                                    android:textSize="14sp"
                                    android:textColor="@color/text_secondary"
                                    android:textAllCaps="false"
                                    app:cornerRadius="20dp"
                                    app:rippleColor="#F3F4F6" />

                            </LinearLayout>

                            <!-- MANUAL ENTRY MODE -->
                            <LinearLayout
                                android:id="@+id/layout_manual_mode"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:padding="32dp"
                                android:visibility="gone">

                                <!-- Back Button -->
                                <LinearLayout
                                    android:id="@+id/btn_back_to_scan"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal"
                                    android:gravity="center_vertical"
                                    android:paddingVertical="8dp"
                                    android:paddingEnd="16dp"
                                    android:background="?attr/selectableItemBackgroundBorderless"
                                    android:clickable="true"
                                    android:focusable="true"
                                    android:layout_marginBottom="16dp">
                                    
                                    <ImageView
                                        android:layout_width="20dp"
                                        android:layout_height="20dp"
                                        android:src="@drawable/ic_arrow_back"
                                        android:tint="@color/text_secondary" />
                                        
                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="@string/back"
                                        android:textSize="14sp"
                                        android:textColor="@color/text_secondary"
                                        android:layout_marginStart="4dp"
                                        android:fontFamily="sans-serif-medium" />
                                </LinearLayout>

                                <!-- Title -->
                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:text="Enter Vehicle Number"
                                    android:textSize="20sp"
                                    android:textColor="@color/text_primary"
                                    android:textStyle="bold"
                                    android:fontFamily="sans-serif-medium"
                                    android:gravity="center"
                                    android:layout_marginBottom="32dp" />

                                <!-- Clean Input Field -->
                                <EditText
                                    android:id="@+id/et_vehicle_number_clean"
                                    android:layout_width="match_parent"
                                    android:layout_height="64dp"
                                    android:hint="@string/op_enter_vehicle_hint"
                                    android:textSize="20sp"
                                    android:textColor="@color/text_primary"
                                    android:textColorHint="#D1D5DB"
                                    android:inputType="textCapCharacters"
                                    android:maxLines="1"
                                    android:gravity="center"
                                    android:background="@drawable/bg_input_clean"
                                    android:padding="16dp"
                                    android:fontFamily="sans-serif-medium"
                                    android:importantForAutofill="no"
                                    android:letterSpacing="0.05" />

                                <!-- Submit Button -->
                                <com.google.android.material.button.MaterialButton
                                    android:id="@+id/btn_submit_manual"
                                    style="@style/Widget.MaterialComponents.Button"
                                    android:layout_width="match_parent"
                                    android:layout_height="60dp"
                                    android:layout_marginTop="32dp"
                                    android:text="@string/op_btn_check_in"
                                    android:textSize="16sp"
                                    android:textColor="@android:color/white"
                                    android:textAllCaps="false"
                                    android:fontFamily="sans-serif-medium"
                                    app:cornerRadius="30dp"
                                    app:backgroundTint="#111827"
                                    app:elevation="4dp" />

                            </LinearLayout>

                        </FrameLayout>

                    </androidx.cardview.widget.CardView>

                </androidx.core.widget.NestedScrollView>

            </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
        
        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- CONTENT: DASHBOARD PAGE (COMING SOON) -->
        <LinearLayout
            android:id="@+id/layout_content_dashboard"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone"
            app:layout_constraintVertical_bias="0.4"
            app:layout_constraintTop_toBottomOf="@id/header_row"
            app:layout_constraintBottom_toTopOf="@id/bottom_navigation_container"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:paddingHorizontal="40dp">

            <com.airbnb.lottie.LottieAnimationView
                android:id="@+id/lottie_dashboard_empty"
                android:layout_width="250dp"
                android:layout_height="250dp"
                app:lottie_fileName="Chart icon.json"
                app:lottie_autoPlay="true"
                app:lottie_loop="true"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Analytics &amp; Insights"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#111827"
                android:fontFamily="@font/inter_bold"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="View occupancy trends and performance metrics. Coming soon to your dashboard."
                android:textSize="15sp"
                android:textColor="#6B7280"
                android:lineSpacingExtra="4dp"
                android:gravity="center"
                android:fontFamily="@font/inter_regular" />

        </LinearLayout>

        <!-- Custom Bottom Navigation -->
        <FrameLayout
            android:id="@+id/bottom_navigation_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/nav_background_edge_to_edge"
            android:elevation="0dp"
            android:fitsSystemWindows="false"
            android:paddingBottom="0dp"
            android:minHeight="60dp"
            app:layout_constraintBottom_toBottomOf="parent">

            <LinearLayout
                android:id="@+id/nav_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:background="@android:color/transparent"
                android:orientation="horizontal"
                android:paddingHorizontal="8dp"
                android:paddingTop="10dp"
                android:paddingBottom="4dp"
                android:clipToPadding="false"
                android:layout_marginBottom="0dp">

                <!-- Scanner Tab -->
                <FrameLayout
                    android:id="@+id/tab_scanner"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:clickable="true"
                    android:focusable="true"
                    android:layout_margin="2dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:paddingBottom="4dp">

                        <FrameLayout
                            android:layout_width="64dp"
                            android:layout_height="32dp"
                            android:layout_marginBottom="6dp"
                            android:background="@drawable/tab_ripple_effect"
                            android:duplicateParentState="true">

                            <View
                                android:id="@+id/scanner_active_bg"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@drawable/active_tab_background"
                                android:visibility="visible" />

                            <ImageView
                                android:id="@+id/iv_scanner"
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_scanner_nav"
                                app:tint="@color/charcoal_black"
                                android:scaleType="centerInside" />
                        </FrameLayout>

                        <TextView
                            android:id="@+id/tv_scanner"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/op_scanner_tab"
                            android:textColor="@color/charcoal_black"
                            android:textSize="12sp"
                            android:fontFamily="@font/inter_medium"
                            android:includeFontPadding="false"
                            android:gravity="center" />

                    </LinearLayout>

                </FrameLayout>

                <!-- Dashboard Tab -->
                <FrameLayout
                    android:id="@+id/tab_dashboard"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:clickable="true"
                    android:focusable="true"
                    android:layout_margin="2dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:paddingBottom="4dp">

                        <FrameLayout
                            android:layout_width="64dp"
                            android:layout_height="32dp"
                            android:layout_marginBottom="6dp"
                            android:background="@drawable/tab_ripple_effect"
                            android:duplicateParentState="true">

                            <View
                                android:id="@+id/dashboard_active_bg"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@drawable/active_tab_background"
                                android:visibility="gone" />

                            <ImageView
                                android:id="@+id/iv_dashboard"
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_dashboard_nav"
                                app:tint="@color/charcoal_black"
                                android:scaleType="centerInside" />
                        </FrameLayout>

                        <TextView
                            android:id="@+id/tv_dashboard"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/op_dashboard_tab"
                            android:textColor="@color/charcoal_black"
                            android:textSize="12sp"
                            android:fontFamily="@font/inter_medium"
                            android:includeFontPadding="false"
                            android:gravity="center" />

                    </LinearLayout>

                </FrameLayout>

            </LinearLayout>

        </FrameLayout>

        <!-- Loading Indicator -->
        <ProgressBar
            android:id="@+id/progress_loading"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="gone"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            tools:visibility="gone" />

        <!-- Custom Dim Overlay (for Sidebar animation) -->
        <View
            android:id="@+id/view_content_shadow"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#000000"
            android:alpha="0"
            android:elevation="10dp" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Navigation Drawer Custom Panel -->
    <include
        android:id="@+id/nav_drawer_panel"
        layout="@layout/layout_operator_drawer_panel"
        android:layout_width="320dp"
        android:layout_height="match_parent"
        android:layout_gravity="start" />

</androidx.drawerlayout.widget.DrawerLayout>
