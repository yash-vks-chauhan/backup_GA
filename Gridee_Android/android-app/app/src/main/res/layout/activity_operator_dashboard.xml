<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="false"
    tools:openDrawer="start">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/main_content"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/background_primary"
        android:clipChildren="false"
        android:clipToPadding="false">

        <!-- ═══════════ HEADER ═══════════ -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/header_row"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:paddingHorizontal="24dp"
            android:paddingBottom="4dp"
            android:clipChildren="false"
            android:clipToPadding="false"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- Profile Avatar -->
            <!-- Ring container -->
            <FrameLayout
                android:layout_width="46dp"
                android:layout_height="46dp"
                android:background="@drawable/bg_avatar_ring"
                android:padding="3dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackgroundBorderless"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/button_menu"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                app:cardBackgroundColor="#4CAF50"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">

                <TextView
                    android:id="@+id/tv_header_initials"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="O"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:fontFamily="@font/inter_bold" />

            </com.google.android.material.card.MaterialCardView>

            </FrameLayout>

            <!-- Centered Header Title -> Now Selected Spot Pill -->
            <LinearLayout
                android:id="@+id/card_selected_spot"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:background="@drawable/bg_segment_track"
                android:paddingStart="16dp"
                android:paddingEnd="12dp"
                android:gravity="center"
                android:orientation="horizontal"
                android:clickable="true"
                android:focusable="true"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <TextView
                    android:id="@+id/et_spot_id"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/op_spot_id_hint"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:fontFamily="@font/inter_semibold" />

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:layout_marginStart="6dp"
                    android:src="@drawable/ic_arrow_down"
                    android:tint="@color/text_primary" />
            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- ═══════════ SCANNER PAGE ═══════════ -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/layout_content_scanner"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layout_constraintTop_toBottomOf="@id/header_row"
            app:layout_constraintBottom_toTopOf="@id/bottom_navigation_container"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- ── Segmented Control (Pill, 40dp — matches home filter) ── -->
            <FrameLayout
                android:id="@+id/segmented_control_container"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_marginTop="16dp"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                android:background="@drawable/bg_segment_track"
                android:padding="3dp"
                android:clipToPadding="false"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <!-- Sliding Indicator -->
                <View
                    android:id="@+id/segment_slider"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:visibility="invisible"
                    android:background="@drawable/bg_segment_slider"
                    android:elevation="2dp" />

                <LinearLayout
                    android:id="@+id/segment_group"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:elevation="4dp">

                    <LinearLayout
                        android:id="@+id/segment_checkin"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:background="?attr/selectableItemBackgroundBorderless">

                        <TextView
                            android:id="@+id/text_checkin"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/op_check_in"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/inter_bold"
                            android:textColor="@color/segment_text_unselected" />

                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/segment_checkout"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:background="?attr/selectableItemBackgroundBorderless">

                        <TextView
                            android:id="@+id/text_checkout"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/op_check_out"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/inter_bold"
                            android:textColor="@color/segment_text_unselected" />

                    </LinearLayout>

                </LinearLayout>

            </FrameLayout>

            <!-- ── Content Area ── -->
            <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
                android:id="@+id/swipe_refresh"
                android:layout_width="0dp"
                android:layout_height="0dp"
                app:layout_constraintTop_toBottomOf="@id/segmented_control_container"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

	                <androidx.core.widget.NestedScrollView
	                    android:layout_width="match_parent"
	                    android:layout_height="match_parent"
	                    android:fillViewport="true"
	                    android:clipToPadding="false"
	                    android:scrollbars="none"
	                    android:paddingTop="32dp"
	                    android:paddingBottom="24dp"
	                    android:paddingHorizontal="24dp">

	                    <LinearLayout
	                        android:layout_width="match_parent"
	                        android:layout_height="wrap_content"
	                        android:orientation="vertical">

	                        <!-- ── Primary Scanner Action ── -->
	                        <FrameLayout
	                            android:id="@+id/card_action"
	                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">

                            <!-- Container for both modes -->
                            <FrameLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content">

                                <!-- ════ SCAN MODE (Default) ════ -->
                                <LinearLayout
                                    android:id="@+id/layout_scan_mode"
	                                    android:layout_width="match_parent"
	                                    android:layout_height="wrap_content"
	                                    android:orientation="vertical"
	                                    android:gravity="center"
	                                    android:visibility="visible">

	                                    <com.google.android.material.card.MaterialCardView
	                                        android:id="@+id/btn_scan_circular"
	                                        android:layout_width="match_parent"
	                                        android:layout_height="80dp"
	                                        android:clickable="true"
	                                        android:focusable="true"
	                                        android:foreground="?attr/selectableItemBackground"
	                                        app:cardBackgroundColor="@color/background_secondary"
	                                        app:cardCornerRadius="28dp"
	                                        app:cardElevation="0dp"
	                                        app:strokeColor="@color/divider_hairline"
	                                        app:strokeWidth="1dp">

                                        <LinearLayout
                                            android:layout_width="match_parent"
	                                            android:layout_height="match_parent"
	                                            android:gravity="center_vertical"
	                                            android:orientation="horizontal"
	                                            android:paddingStart="16dp"
	                                            android:paddingEnd="20dp">

	                                            <com.google.android.material.card.MaterialCardView
	                                                android:layout_width="52dp"
	                                                android:layout_height="52dp"
	                                                app:cardBackgroundColor="@color/brand_primary"
	                                                app:cardCornerRadius="26dp"
	                                                app:cardElevation="0dp"
	                                                app:strokeWidth="0dp">

	                                                <ImageView
	                                                    android:layout_width="24dp"
	                                                    android:layout_height="24dp"
	                                                    android:layout_gravity="center"
	                                                    android:contentDescription="@null"
	                                                    android:src="@drawable/ic_camera"
                                                    android:tint="@color/btn_text_on_brand" />
                                            </com.google.android.material.card.MaterialCardView>

                                            <TextView
	                                                android:layout_width="0dp"
	                                                android:layout_height="wrap_content"
	                                                android:layout_marginStart="18dp"
	                                                android:layout_weight="1"
	                                                android:fontFamily="@font/inter_semibold"
	                                                android:includeFontPadding="false"
	                                                android:text="@string/scanner_open"
	                                                android:textColor="@color/text_primary"
	                                                android:textSize="18sp" />

	                                            <ImageView
	                                                android:layout_width="20dp"
	                                                android:layout_height="20dp"
	                                                android:contentDescription="@null"
	                                                android:src="@drawable/ic_chevron_right"
	                                                android:tint="@color/text_secondary" />
                                        </LinearLayout>

                                    </com.google.android.material.card.MaterialCardView>

                                    <!-- Manual Entry — Secondary Action -->
                                    <com.google.android.material.button.MaterialButton
                                        android:id="@+id/link_manual_entry"
                                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                                        android:layout_width="match_parent"
                                        android:layout_height="56dp"
                                        android:layout_marginTop="40dp"
                                        android:visibility="gone"
                                        android:text="@string/op_manual_entry_label"
                                        android:textSize="16sp"
                                        android:textColor="@color/text_primary"
                                        android:textAllCaps="false"
                                        android:fontFamily="@font/inter_semibold"
                                        app:cornerRadius="16dp"
                                        app:strokeColor="@color/border_light"
                                        app:strokeWidth="1dp"
                                        app:rippleColor="@color/segment_hover" />

                                </LinearLayout>

                                <!-- ════ MANUAL ENTRY MODE ════ -->
                                <LinearLayout
                                    android:id="@+id/layout_manual_mode"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="vertical"
                                    android:paddingHorizontal="24dp"
                                    android:paddingTop="24dp"
                                    android:paddingBottom="40dp"
                                    android:visibility="gone">

                                    <!-- Back to Scan -->
                                    <LinearLayout
                                        android:id="@+id/btn_back_to_scan"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:orientation="horizontal"
                                        android:gravity="center_vertical"
                                        android:paddingVertical="8dp"
                                        android:paddingEnd="16dp"
                                        android:background="?attr/selectableItemBackgroundBorderless"
                                        android:clickable="true"
                                        android:focusable="true">

                                        <ImageView
                                            android:layout_width="20dp"
                                            android:layout_height="20dp"
                                            android:src="@drawable/ic_arrow_back"
                                            android:tint="@color/text_secondary" />

                                        <TextView
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:text="@string/back"
                                            android:textSize="15sp"
                                            android:textColor="@color/text_secondary"
                                            android:layout_marginStart="6dp"
                                            android:fontFamily="@font/inter_medium" />

                                    </LinearLayout>

                                    <!-- Input Field -->
                                    <com.google.android.material.card.MaterialCardView
                                        android:layout_width="match_parent"
                                        android:layout_height="64dp"
                                        android:layout_marginTop="32dp"
                                        app:cardCornerRadius="16dp"
                                        app:cardElevation="0dp"
                                        app:strokeWidth="1dp"
                                        app:strokeColor="@color/border_light"
                                        app:cardBackgroundColor="@color/background_secondary">

                                        <EditText
                                            android:id="@+id/et_vehicle_number_clean"
                                            android:layout_width="match_parent"
                                            android:layout_height="match_parent"
                                            android:hint="@string/op_enter_vehicle_hint"
                                            android:textSize="22sp"
                                            android:textColor="@color/text_primary"
                                            android:textColorHint="@color/text_tertiary"
                                            android:inputType="textCapCharacters|textNoSuggestions"
                                            android:maxLength="16"
                                            android:maxLines="1"
                                            android:gravity="center"
                                            android:background="@null"
                                            android:paddingHorizontal="24dp"
                                            android:fontFamily="@font/inter_bold"
                                            android:importantForAutofill="no"
                                            android:letterSpacing="0.05" />

                                    </com.google.android.material.card.MaterialCardView>

                                    <!-- Submit Button (Primary Action) -->
                                    <com.google.android.material.button.MaterialButton
                                        android:id="@+id/btn_submit_manual"
                                        style="@style/Widget.MaterialComponents.Button"
                                        android:layout_width="match_parent"
                                        android:layout_height="56dp"
                                        android:layout_marginTop="24dp"
                                        android:text="@string/op_btn_check_in"
                                        android:textSize="16sp"
                                        android:textColor="@android:color/white"
                                        android:textAllCaps="false"
                                        android:fontFamily="@font/inter_semibold"
                                        app:cornerRadius="16dp"
                                        app:backgroundTint="#111827"
                                        app:elevation="0dp" />

                                </LinearLayout>

                            </FrameLayout>

                        </FrameLayout>

                    </LinearLayout>

                </androidx.core.widget.NestedScrollView>

            </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- ═══════════ DASHBOARD PAGE (Coming Soon) ═══════════ -->
        <LinearLayout
            android:id="@+id/layout_content_dashboard"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone"
            app:layout_constraintVertical_bias="0.4"
            app:layout_constraintTop_toBottomOf="@id/header_row"
            app:layout_constraintBottom_toTopOf="@id/bottom_navigation_container"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:paddingHorizontal="40dp">

            <com.airbnb.lottie.LottieAnimationView
                android:id="@+id/lottie_dashboard_empty"
                android:layout_width="200dp"
                android:layout_height="200dp"
                app:lottie_fileName="Chart icon.json"
                app:lottie_autoPlay="true"
                app:lottie_loop="true"
                android:layout_marginBottom="20dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Analytics &amp; Insights"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:fontFamily="@font/inter_bold"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="View occupancy trends and performance metrics. Coming soon to your dashboard."
                android:textSize="15sp"
                android:textColor="@color/text_secondary"
                android:lineSpacingExtra="4dp"
                android:gravity="center"
                android:fontFamily="@font/inter_regular" />

        </LinearLayout>

        <!-- ═══════════ BOTTOM NAVIGATION ═══════════ -->
        <FrameLayout
            android:id="@+id/bottom_navigation_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/nav_background_edge_to_edge"
            android:elevation="0dp"
            android:fitsSystemWindows="false"
            android:paddingBottom="0dp"
            android:minHeight="60dp"
            app:layout_constraintBottom_toBottomOf="parent">

            <LinearLayout
                android:id="@+id/nav_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:background="@android:color/transparent"
                android:orientation="horizontal"
                android:paddingHorizontal="8dp"
                android:paddingTop="10dp"
                android:paddingBottom="4dp"
                android:clipToPadding="false"
                android:layout_marginBottom="0dp">

                <!-- Scanner Tab -->
                <FrameLayout
                    android:id="@+id/tab_scanner"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:clickable="true"
                    android:focusable="true"
                    android:layout_margin="2dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:paddingBottom="4dp">

                        <FrameLayout
                            android:layout_width="64dp"
                            android:layout_height="32dp"
                            android:layout_marginBottom="6dp"
                            android:background="@drawable/tab_ripple_effect"
                            android:duplicateParentState="true">

                            <View
                                android:id="@+id/scanner_active_bg"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@drawable/active_tab_background"
                                android:visibility="visible" />

                            <ImageView
                                android:id="@+id/iv_scanner"
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_scanner_nav"
                                app:tint="@color/charcoal_black"
                                android:scaleType="centerInside" />

                        </FrameLayout>

                        <TextView
                            android:id="@+id/tv_scanner"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/op_scanner_tab"
                            android:textColor="@color/charcoal_black"
                            android:textSize="12sp"
                            android:fontFamily="@font/inter_medium"
                            android:includeFontPadding="false"
                            android:gravity="center" />

                    </LinearLayout>

                </FrameLayout>

                <!-- Dashboard Tab -->
                <FrameLayout
                    android:id="@+id/tab_dashboard"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:clickable="true"
                    android:focusable="true"
                    android:layout_margin="2dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:paddingBottom="4dp">

                        <FrameLayout
                            android:layout_width="64dp"
                            android:layout_height="32dp"
                            android:layout_marginBottom="6dp"
                            android:background="@drawable/tab_ripple_effect"
                            android:duplicateParentState="true">

                            <View
                                android:id="@+id/dashboard_active_bg"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@drawable/active_tab_background"
                                android:visibility="gone" />

                            <ImageView
                                android:id="@+id/iv_dashboard"
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_dashboard_nav"
                                app:tint="@color/charcoal_black"
                                android:scaleType="centerInside" />

                        </FrameLayout>

                        <TextView
                            android:id="@+id/tv_dashboard"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/op_dashboard_tab"
                            android:textColor="@color/charcoal_black"
                            android:textSize="12sp"
                            android:fontFamily="@font/inter_medium"
                            android:includeFontPadding="false"
                            android:gravity="center" />

                    </LinearLayout>

                </FrameLayout>

            </LinearLayout>

        </FrameLayout>

        <!-- Loading Indicator -->
        <ProgressBar
            android:id="@+id/progress_loading"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="gone"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            tools:visibility="gone" />

        <!-- Dim Overlay -->
        <View
            android:id="@+id/view_content_shadow"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#000000"
            android:alpha="0"
            android:elevation="10dp" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Navigation Drawer -->
    <include
        android:id="@+id/nav_drawer_panel"
        layout="@layout/layout_operator_drawer_panel"
        android:layout_width="320dp"
        android:layout_height="match_parent"
        android:layout_gravity="start" />

</androidx.drawerlayout.widget.DrawerLayout>
