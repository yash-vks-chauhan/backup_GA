<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/card_spot"
    android:layout_width="200dp"
    android:layout_height="250dp"
    android:layout_marginHorizontal="8dp"
    android:layout_marginVertical="8dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    app:cardBackgroundColor="@android:color/white"
    app:cardCornerRadius="28dp"
    app:cardElevation="2dp"
    app:strokeWidth="1dp"
    app:strokeColor="#E5E7EB"
    app:rippleColor="#10000000">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_card_surface_gradient"
        android:padding="20dp">

        <!-- Header: Live Status Pill -->
        <LinearLayout
            android:id="@+id/layout_live_pill"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_status_pill_live"
            android:paddingHorizontal="10dp"
            android:paddingVertical="6dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <FrameLayout
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:layout_marginEnd="6dp">

                <!-- Faint Ripple (Visual only) -->
                <View
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:background="@drawable/shape_circle_green_faint"
                    android:alpha="0.5"/>

                <!-- Core Dot -->
                <View
                    android:layout_width="6dp"
                    android:layout_height="6dp"
                    android:layout_gravity="center"
                    android:background="@drawable/shape_status_dot_active"/>
            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="LIVE"
                android:textSize="11sp"
                android:textColor="#059669"
                android:textStyle="bold"
                android:fontFamily="@font/inter_bold"
                android:letterSpacing="0.05"/>
        </LinearLayout>

        <!-- Spot Name -->
        <TextView
            android:id="@+id/tv_spot_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Phoenix Mall"
            android:textColor="#111827"
            android:textSize="22sp"
            android:fontFamily="@font/inter_bold"
            android:letterSpacing="-0.03"
            android:lineHeight="28sp"
            android:maxLines="2"
            android:ellipsize="end"
            app:layout_constraintTop_toBottomOf="@id/layout_live_pill"
            app:layout_constraintStart_toStartOf="parent"/>

        <!-- Availability Section (Grouped with Name) -->
        <TextView
            android:id="@+id/tv_spot_availability"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="14"
            android:textColor="#059669"
            android:textSize="44sp"
            android:textStyle="bold"
            android:fontFamily="@font/inter_bold"
            android:letterSpacing="-0.04"
            android:includeFontPadding="false"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/tv_spot_name"
            app:layout_constraintStart_toStartOf="parent"/>

        <TextView
            android:id="@+id/tv_label_spots"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SPOTS AVAILABLE"
            android:textColor="#6B7280"
            android:textSize="12sp"
            android:textStyle="bold"
            android:fontFamily="@font/inter_bold"
            android:letterSpacing="0.05"
            android:layout_marginTop="2dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_spot_availability"/>

        <!-- Action Arrow Button -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="40dp"
            android:layout_height="40dp"
            app:cardCornerRadius="20dp"
            app:cardBackgroundColor="#F3F4F6"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="#E5E7EB"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_arrow_right"
                android:layout_gravity="center"
                app:tint="#111827"/>

        </com.google.android.material.card.MaterialCardView>

        <!-- Compat Helpers (Hidden) -->
        <TextView android:id="@+id/tv_price_pill" android:layout_width="wrap_content" android:layout_height="wrap_content" android:visibility="gone" app:layout_constraintBottom_toTopOf="parent"/>
        <LinearLayout android:id="@+id/layout_badge" android:layout_width="wrap_content" android:layout_height="wrap_content" android:visibility="gone" app:layout_constraintBottom_toTopOf="parent"/>
        <LinearLayout android:id="@+id/layout_location_meta" android:layout_width="wrap_content" android:layout_height="wrap_content" android:visibility="gone" app:layout_constraintBottom_toTopOf="parent"><TextView android:id="@+id/tv_spot_meta" android:layout_width="wrap_content" android:layout_height="wrap_content"/></LinearLayout>
        <LinearLayout android:id="@+id/layout_live_status" android:layout_width="match_parent" android:layout_height="wrap_content" android:visibility="gone" app:layout_constraintTop_toTopOf="parent"/>
        <LinearLayout android:id="@+id/layout_status_minimal" android:layout_width="wrap_content" android:layout_height="wrap_content" android:visibility="gone" app:layout_constraintTop_toTopOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>
