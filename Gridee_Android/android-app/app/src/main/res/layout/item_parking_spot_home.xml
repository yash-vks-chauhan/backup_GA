<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/card_spot"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="16dp"
    android:layout_marginTop="0dp"
    android:layout_marginEnd="16dp"
    android:layout_marginBottom="16dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    android:outlineAmbientShadowColor="#1A000000"
    android:outlineSpotShadowColor="#33000000"
    app:cardBackgroundColor="@color/background_secondary"
    app:cardCornerRadius="30dp"
    app:cardElevation="3dp"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:paddingVertical="14dp">

        <!-- Custom Icon Circle -->
        <FrameLayout
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/circle_light_gray_background"
            android:layout_marginEnd="14dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_home_card_motorcycle"
                app:tint="@color/text_primary"/>
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_spot_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:fontFamily="@font/inter_bold"
                android:textStyle="bold"
                android:letterSpacing="-0.01"
                android:layout_marginBottom="4dp"
                android:maxLines="1"
                android:ellipsize="end"
                tools:text="TP Avenue" />

            <LinearLayout
                android:id="@+id/layout_availability"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/status_soft_active"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:layout_marginTop="0dp">

                <View
                    android:id="@+id/view_status_dot"
                    android:layout_width="6dp"
                    android:layout_height="6dp"
                    android:background="@drawable/bg_dot_inactive"
                    android:backgroundTint="@color/parking_spot_available"
                    android:layout_marginEnd="6dp" />

                <TextView
                    android:id="@+id/tv_spot_availability"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/parking_spot_available"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/inter_semibold"
                    tools:text="400 Available" />
            </LinearLayout>

        </LinearLayout>

        <!-- Bold Book Button -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btn_book"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/gray_200"
            app:cardCornerRadius="100dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp"
            android:clickable="false"
            android:focusable="false"
            android:layout_marginStart="8dp">
            
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="18dp"
                android:paddingVertical="10dp"
                android:fontFamily="@font/inter_semibold"
                android:text="Park"
                android:textColor="@color/text_primary"
                android:textSize="14sp" />
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
