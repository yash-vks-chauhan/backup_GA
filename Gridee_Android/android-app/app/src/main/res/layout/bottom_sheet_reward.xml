<?xml version="1.0" encoding="utf-8"?>
<!-- "The Mint" — the daily-reward sheet. A dark obsidian chamber up top (the
     home hero's material) cradles the medallion that flew in from the header;
     a light content surface rises into it on a curved seam. See RewardBottomSheet. -->
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/reward_scroll"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@android:color/transparent"
    android:fillViewport="true"
    android:overScrollMode="never">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:clipChildren="false"
        android:clipToPadding="false">

        <!-- ── The obsidian minting chamber (back layer) ───────────────────── -->
        <View
            android:id="@+id/chamber"
            android:layout_width="match_parent"
            android:layout_height="264dp"
            android:background="@drawable/bg_reward_chamber"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- ── Gold halo behind the medallion (over chamber, behind content) ── -->
        <View
            android:id="@+id/chamber_glow"
            android:layout_width="240dp"
            android:layout_height="240dp"
            android:background="@drawable/bg_reward_chamber_glow"
            app:layout_constraintBottom_toBottomOf="@+id/hero_medallion"
            app:layout_constraintEnd_toEndOf="@+id/hero_medallion"
            app:layout_constraintStart_toStartOf="@+id/hero_medallion"
            app:layout_constraintTop_toTopOf="@+id/hero_medallion" />

        <!-- ── Light content surface, rising into the chamber on a curved seam ─ -->
        <LinearLayout
            android:id="@+id/content_surface"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="220dp"
            android:background="@drawable/bg_reward_content_surface"
            android:orientation="vertical"
            android:paddingStart="28dp"
            android:paddingTop="40dp"
            android:paddingEnd="28dp"
            android:paddingBottom="18dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <!-- Eyebrow — the quietest tier: small, Medium weight, tertiary colour,
                 wide tracking. A label that recedes so the value below is the hero. -->
            <TextView
                android:id="@+id/tv_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/inter_semibold"
                android:gravity="center"
                android:letterSpacing="0.08"
                android:text="Daily reward"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />

            <!-- Reward value — the minted figure, set big in gold (counts up,
                 catches the coin's glint). "coins" rides its baseline. -->
            <LinearLayout
                android:id="@+id/reward_amount_block"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="6dp"
                android:baselineAligned="true"
                android:orientation="horizontal">

                <com.gridee.parking.ui.views.RewardAmountView
                    android:id="@+id/reward_amount_view"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:contentDescription="Reward amount" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:fontFamily="@font/inter_semibold"
                    android:text="coins"
                    android:textColor="@color/text_secondary"
                    android:textSize="15sp" />
            </LinearLayout>

            <!-- Subtitle -->
            <TextView
                android:id="@+id/tv_subtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:fontFamily="@font/inter_regular"
                android:gravity="center"
                android:lineSpacingExtra="3dp"
                android:text="Watch a short clip — minted straight to your wallet"
                android:textColor="@color/text_secondary"
                android:textSize="14sp" />

            <!-- Primary CTA -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_primary"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="22dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:fontFamily="@font/inter_bold"
                android:letterSpacing="0.01"
                android:text="Watch &amp; claim"
                android:textAllCaps="false"
                android:textSize="17sp"
                app:cornerRadius="28dp"
                app:rippleColor="#33FFFFFF" />

            <!-- Hairline separating the daily claim from the quiet rating prompt. -->
            <View
                android:id="@+id/earn_header"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="28dp"
                android:background="@color/divider" />

            <!-- Quiet rating prompt — one centered line, gold only on the tappable
                 word. Opens Google's in-app review card (no incentive — Play policy
                 forbids rewarding reviews). See RewardBottomSheet. -->
            <LinearLayout
                android:id="@+id/earn_row"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="18dp"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingTop="6dp"
                android:paddingBottom="6dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/inter_regular"
                    android:text="Enjoying Gridee?"
                    android:textColor="@color/text_secondary"
                    android:textSize="13.5sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:fontFamily="@font/inter_bold"
                    android:text="Rate us"
                    android:textColor="@color/reward_amount_text"
                    android:textSize="13.5sp" />
            </LinearLayout>

            <!-- Fine print -->
            <TextView
                android:id="@+id/tv_reward_note"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:fontFamily="@font/inter_regular"
                android:gravity="center"
                android:text="A new reward every day"
                android:textColor="@color/text_tertiary"
                android:textSize="12sp" />

        </LinearLayout>

        <!-- ── The hero medallion (lands here from the flight) ─────────────── -->
        <com.gridee.parking.ui.views.RewardCoinView
            android:id="@+id/hero_medallion"
            android:layout_width="150dp"
            android:layout_height="150dp"
            android:layout_marginTop="52dp"
            android:contentDescription="Daily reward"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- ── Chamber chrome ──────────────────────────────────────────────── -->
        <View
            android:id="@+id/drag_handle"
            android:layout_width="36dp"
            android:layout_height="5dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/handle_pill_on_dark"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/btn_close"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="16dp"
            android:background="@drawable/bg_close_circle_on_dark"
            android:clickable="true"
            android:contentDescription="Close"
            android:focusable="true"
            android:padding="9dp"
            android:src="@drawable/ic_close"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="#E8FFFFFF" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.core.widget.NestedScrollView>
