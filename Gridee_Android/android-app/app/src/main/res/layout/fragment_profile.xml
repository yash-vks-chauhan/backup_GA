<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_primary"
    android:fitsSystemWindows="false">

    <!-- Scrollable Content — full-bleed, scrolls behind the transparent toolbar -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollContent"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:scrollbars="none"
        android:clipToPadding="false">

        <LinearLayout
            android:id="@+id/content_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="32dp">

        <!-- Profile Header (Open Design) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="32dp"
            android:paddingBottom="16dp"
            android:clipChildren="false"
            android:clipToPadding="false">

            <!-- Master Identity Container (Holds Avatar + Floating Badge) -->
            <FrameLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:clipChildren="false"
                android:clipToPadding="false">

                <!-- Avatar Card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="104dp"
                    android:layout_height="104dp"
                    android:layout_margin="8dp"
                    app:cardCornerRadius="52dp"
                    app:cardElevation="2dp"
                    app:cardMaxElevation="3dp"
                    app:cardPreventCornerOverlap="false"
                    app:cardBackgroundColor="@color/avatar_ring">

                    <!-- Inner Container for White Border -->
                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_margin="5dp">

                        <FrameLayout
                            android:id="@+id/card_profile_avatar"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@drawable/circle_background_green"
                            android:foreground="@drawable/bg_ios_row_press"
                            android:clickable="true"
                            android:focusable="true">

                            <TextView
                                android:id="@+id/tv_user_initials"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:textColor="#FFFFFF"
                                android:textSize="36sp"
                                android:textStyle="bold"
                                android:gravity="center"
                                android:fontFamily="@font/inter_bold"
                                tools:text="YC" />

                        </FrameLayout>
                    </FrameLayout>

                </androidx.cardview.widget.CardView>

                <!-- Floating Badge (Outside CardView to prevent clipping) -->
                <FrameLayout
                    android:id="@+id/btn_edit_profile"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:layout_gravity="bottom|end"
                    android:layout_marginEnd="4dp"
                    android:layout_marginBottom="4dp"
                    android:background="@drawable/bg_badge_circle_border"
                    android:clickable="true"
                    android:focusable="true"
                    android:elevation="12dp">

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_edit_profile"
                        android:tint="#FFFFFF"
                        android:importantForAccessibility="no" />

                </FrameLayout>

            </FrameLayout>

            <!-- User Name -->
            <TextView
                android:id="@+id/tv_user_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:textSize="26sp"
                android:textStyle="bold"
                android:fontFamily="@font/inter_bold"
                android:layout_marginTop="16dp"
                android:letterSpacing="0.01"
                tools:text="Yash Chauhan" />

        </LinearLayout>

        <!-- Account Section Header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Account"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:textStyle="bold"
            android:fontFamily="@font/inter_bold"
            android:letterSpacing="0.01"
            android:layout_marginStart="20dp"
            android:layout_marginBottom="12dp"
            android:layout_marginTop="24dp" />

        <!-- Account & Profile Category -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="36dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/background_secondary">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Account Settings -->
                <LinearLayout
                    android:id="@+id/btn_account_settings"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingVertical="18dp"
                    android:paddingHorizontal="20dp"
                    android:background="@drawable/bg_ios_row_press"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_account_settings"
                        android:tint="@color/icon_secondary"
                        android:layout_marginEnd="16dp" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Account Settings"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"
                        android:fontFamily="@font/inter_medium" />

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_arrow_right"
                        android:tint="@color/text_tertiary" />

                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="0.5dp"
                    android:layout_marginStart="60dp"
                    android:layout_marginEnd="20dp"
                    android:background="@color/divider_hairline" />

                <!-- Notifications -->
                <LinearLayout
                    android:id="@+id/btn_notifications"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingVertical="18dp"
                    android:paddingHorizontal="20dp"
                    android:background="@drawable/bg_ios_row_press"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_notifications"
                        android:tint="@color/icon_secondary"
                        android:layout_marginEnd="16dp" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Notifications"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"
                        android:fontFamily="@font/inter_medium" />

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_arrow_right"
                        android:tint="@color/text_tertiary" />

                </LinearLayout>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Vehicle Section Header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Bookings &amp; Vehicles"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:textStyle="bold"
            android:fontFamily="@font/inter_bold"
            android:letterSpacing="0.01"
            android:layout_marginStart="20dp"
            android:layout_marginBottom="12dp"
            android:layout_marginTop="24dp" />

        <!-- Vehicle Management Category -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="36dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/background_secondary">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Booking History -->
                <LinearLayout
                    android:id="@+id/btn_booking_history"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingVertical="18dp"
                    android:paddingHorizontal="20dp"
                    android:background="@drawable/bg_ios_row_press"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_booking_history_ticket"
                        android:tint="@color/icon_secondary"
                        android:layout_marginEnd="16dp" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Booking History"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"
                        android:fontFamily="@font/inter_medium" />

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_arrow_right"
                        android:tint="@color/text_tertiary" />

                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="0.5dp"
                    android:layout_marginStart="60dp"
                    android:layout_marginEnd="20dp"
                    android:background="@color/divider_hairline" />

                <!-- My Vehicles (Accordion) -->
                <LinearLayout
                    android:id="@+id/btn_my_vehicles"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingVertical="18dp"
                    android:paddingHorizontal="20dp"
                    android:background="@drawable/bg_ios_row_press"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_car_outlined"
                        android:tint="@color/icon_secondary"
                        android:layout_marginEnd="16dp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="My Vehicles"
                            android:textColor="@color/text_primary"
                            android:textSize="16sp"
                            android:fontFamily="@font/inter_medium" />

                        <TextView
                            android:id="@+id/tv_vehicle_count"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/profile_vehicle_count_loading"
                            android:textColor="@color/text_tertiary"
                            android:textSize="13sp"
                            android:fontFamily="@font/inter_regular"
                            android:layout_marginTop="2dp"
                            tools:text="2 vehicles" />

                    </LinearLayout>

                    <ImageView
                        android:id="@+id/iv_vehicles_expand"
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_arrow_down"
                        android:tint="@color/text_tertiary" />

                </LinearLayout>

                <!-- Expandable Vehicle List -->
                <LinearLayout
                    android:id="@+id/layout_vehicles_expanded"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone"
                    android:alpha="0">

                    <!-- Vehicle List Container - Dynamically populated -->
                    <LinearLayout
                        android:id="@+id/vehicles_container"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingStart="56dp"
                        android:paddingEnd="16dp"
                        android:paddingTop="12dp"
                        android:paddingBottom="12dp">

                        <!-- Vehicles will be added dynamically here -->

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Preferences Section Header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Preferences"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:textStyle="bold"
            android:fontFamily="@font/inter_bold"
            android:letterSpacing="0.01"
            android:layout_marginStart="20dp"
            android:layout_marginBottom="12dp"
            android:layout_marginTop="24dp" />

        <!-- App Preferences Category -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="36dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/background_secondary">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Display & Theme -->
                <LinearLayout
                    android:id="@+id/btn_display_theme"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingVertical="18dp"
                    android:paddingHorizontal="20dp"
                    android:background="@drawable/bg_ios_row_press"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_display"
                        android:tint="@color/icon_secondary"
                        android:layout_marginEnd="16dp" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Display &amp; Theme"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"
                        android:fontFamily="@font/inter_medium" />

                    <TextView
                        android:id="@+id/tv_display_theme_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="System"
                        android:textColor="@color/text_tertiary"
                        android:textSize="15sp"
                        android:fontFamily="@font/inter_regular"
                        android:layout_marginEnd="8dp" />

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_arrow_right"
                        android:tint="@color/text_tertiary" />

                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="0.5dp"
                    android:layout_marginStart="60dp"
                    android:layout_marginEnd="20dp"
                    android:background="@color/divider_hairline" />

                <!-- Language & Region -->
                <LinearLayout
                    android:id="@+id/btn_language_region"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingVertical="18dp"
                    android:paddingHorizontal="20dp"
                    android:background="@drawable/bg_ios_row_press"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_language"
                        android:tint="@color/icon_secondary"
                        android:layout_marginEnd="16dp" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Language &amp; Region"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"
                        android:fontFamily="@font/inter_medium" />

                    <TextView
                        android:id="@+id/tv_language_region_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="English"
                        android:textColor="@color/text_tertiary"
                        android:textSize="15sp"
                        android:fontFamily="@font/inter_regular"
                        android:layout_marginEnd="8dp" />

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_arrow_right"
                        android:tint="@color/text_tertiary" />

                </LinearLayout>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Legal Section Header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Legal &amp; Support"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:textStyle="bold"
            android:fontFamily="@font/inter_bold"
            android:letterSpacing="0.01"
            android:layout_marginStart="20dp"
            android:layout_marginBottom="12dp"
            android:layout_marginTop="24dp" />

        <!-- Support & Legal Category -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="36dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/background_secondary">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Help & Support -->
                <LinearLayout
                    android:id="@+id/btn_help_support"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingVertical="18dp"
                    android:paddingHorizontal="20dp"
                    android:background="@drawable/bg_ios_row_press"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_help"
                        android:tint="@color/icon_secondary"
                        android:layout_marginEnd="16dp" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Help &amp; Support"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"
                        android:fontFamily="@font/inter_medium" />

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_arrow_right"
                        android:tint="@color/text_tertiary" />

                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="0.5dp"
                    android:layout_marginStart="60dp"
                    android:layout_marginEnd="20dp"
                    android:background="@color/divider_hairline" />

                <!-- Privacy Policy -->
                <LinearLayout
                    android:id="@+id/btn_privacy_policy"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingVertical="18dp"
                    android:paddingHorizontal="20dp"
                    android:background="@drawable/bg_ios_row_press"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_privacy_policy"
                        android:tint="@color/icon_secondary"
                        android:layout_marginEnd="16dp" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Privacy Policy"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"
                        android:fontFamily="@font/inter_medium" />

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_arrow_right"
                        android:tint="@color/text_tertiary" />

                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="0.5dp"
                    android:layout_marginStart="60dp"
                    android:layout_marginEnd="20dp"
                    android:background="@color/divider_hairline" />

                <!-- Data Safety -->
                <LinearLayout
                    android:id="@+id/btn_data_safety"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingVertical="18dp"
                    android:paddingHorizontal="20dp"
                    android:background="@drawable/bg_ios_row_press"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_data_safety"
                        android:tint="@color/icon_secondary"
                        android:layout_marginEnd="16dp" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Data Safety &amp; Account Deletion"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"
                        android:fontFamily="@font/inter_medium" />

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_arrow_right"
                        android:tint="@color/text_tertiary" />

                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="0.5dp"
                    android:layout_marginStart="60dp"
                    android:layout_marginEnd="20dp"
                    android:background="@color/divider_hairline" />

                <!-- About -->
                <LinearLayout
                    android:id="@+id/btn_about"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingVertical="18dp"
                    android:paddingHorizontal="20dp"
                    android:background="@drawable/bg_ios_row_press"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_info"
                        android:tint="@color/icon_secondary"
                        android:layout_marginEnd="16dp" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="About"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"
                        android:fontFamily="@font/inter_medium" />

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_arrow_right"
                        android:tint="@color/text_tertiary" />

                </LinearLayout>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Session Section Header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Session"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:textStyle="bold"
            android:fontFamily="@font/inter_bold"
            android:letterSpacing="0.01"
            android:layout_marginStart="20dp"
            android:layout_marginBottom="12dp"
            android:layout_marginTop="24dp" />

        <!-- Logout Section -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="36dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/background_secondary">

            <LinearLayout
                android:id="@+id/btn_logout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="18dp"
                android:paddingHorizontal="20dp"
                android:background="@drawable/bg_ios_row_press"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_logout"
                    android:tint="@color/text_destructive"
                    android:layout_marginEnd="16dp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Logout"
                    android:textColor="@color/text_destructive"
                    android:textSize="16sp"
                    android:fontFamily="@font/inter_medium" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- Unified frosted header overlay — gradient from opaque at top to transparent at bottom.
         One single view that covers both toolbar area + dissolve zone below.
         No separate fog overlay, no z-fighting, totally seamless. -->
    <View
        android:id="@+id/view_toolbar_frost"
        android:layout_width="match_parent"
        android:layout_height="112dp"
        android:layout_gravity="top"
        android:background="@drawable/bg_toolbar_frosted"
        android:alpha="0" />

    <!-- Toolbar title — floats on top of everything -->
    <TextView
