<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_bottom_sheet_universal"
    android:paddingBottom="0dp"
    android:clipChildren="false"
    android:clipToPadding="false">

    <!-- Drag Handle -->
    <View
        android:id="@+id/drag_handle"
        android:layout_width="32dp"
        android:layout_height="4dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/handle_pill_minimal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Close Button -->
    <ImageView
        android:id="@+id/btn_close"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_marginTop="20dp"
        android:layout_marginEnd="20dp"
        android:background="@drawable/bg_close_circle"
        android:src="@drawable/ic_close"
        android:padding="9dp"
        app:tint="#5C5C5C"
        android:clickable="true"
        android:focusable="true"
        android:contentDescription="Close"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:elevation="2dp"/>

    <!-- Scrollable Content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@id/drag_handle"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginTop="8dp"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingBottom="32dp">

            <!-- Title -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="40dp"
                android:fontFamily="@font/inter_bold"
                android:gravity="center"
                android:text="Add Money"
                android:textColor="#1A1A1A"
                android:textSize="22sp" />

            <!-- Current Balance (Clean Minimalist) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginBottom="40dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CURRENT BALANCE"
                    android:letterSpacing="0.05"
                    android:fontFamily="@font/inter_medium"
                    android:textSize="12sp"
                    android:textColor="#5C5C5C"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:id="@+id/tv_current_balance"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="₹0.00"
                    android:fontFamily="@font/inter_bold"
                    android:textSize="40sp"
                    android:textColor="#1A1A1A"/>

            </LinearLayout>

            <!-- Auto-Select/Input Header -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Enter Amount"
                android:textColor="#1A1A1A"
                android:textSize="14sp"
                android:fontFamily="@font/inter_medium"
                android:layout_marginBottom="12dp" />

            <!-- Rounded Input Field -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:boxBackgroundMode="outline"
                app:boxCornerRadiusBottomEnd="30dp"
                app:boxCornerRadiusBottomStart="30dp"
                app:boxCornerRadiusTopEnd="30dp"
                app:boxCornerRadiusTopStart="30dp"
                app:boxStrokeColor="#E0E0E0"
                app:boxStrokeWidth="1.5dp"
                app:hintEnabled="false">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_amount"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="numberDecimal"
                    android:textSize="18sp"
                    android:textColor="#1A1A1A"
                    android:fontFamily="@font/inter_semibold"
                    android:paddingTop="18dp"
                    android:paddingBottom="18dp"
                    android:hint="₹ 0.00"
                    android:textColorHint="#9E9E9E"/>

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Quick Chips -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="48dp"
                android:weightSum="4"
                android:baselineAligned="false">

                <Button
                    android:id="@+id/btn_amount_50"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:text="₹50"
                    android:textColor="#1A1A1A"
                    android:textSize="13sp"
                    android:fontFamily="@font/inter_medium"
                    app:strokeColor="#E0E0E0"
                    app:strokeWidth="1dp"
                    app:cornerRadius="24dp"
                    android:padding="0dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"/>

                <Button
                    android:id="@+id/btn_amount_100"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:text="₹100"
                    android:textColor="#1A1A1A"
                    android:textSize="13sp"
                    android:fontFamily="@font/inter_medium"
                    app:strokeColor="#E0E0E0"
                    app:strokeWidth="1dp"
                    app:cornerRadius="24dp"
                    android:padding="0dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"/>

                <Button
                    android:id="@+id/btn_amount_200"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:text="₹200"
                    android:textColor="#1A1A1A"
                    android:textSize="13sp"
                    android:fontFamily="@font/inter_medium"
                    app:strokeColor="#E0E0E0"
                    app:strokeWidth="1dp"
                    app:cornerRadius="24dp"
                    android:padding="0dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"/>

                <Button
                    android:id="@+id/btn_amount_500"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="₹500"
                    android:textColor="#1A1A1A"
                    android:textSize="13sp"
                    android:fontFamily="@font/inter_medium"
                    app:strokeColor="#E0E0E0"
                    app:strokeWidth="1dp"
                    app:cornerRadius="24dp"
                    android:padding="0dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"/>
            </LinearLayout>

            <!-- Main Action Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_add_money_confirm"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="Add Money"
                android:textSize="16sp"
                android:fontFamily="@font/inter_semibold"
                android:backgroundTint="#1A1A1A"
                android:textColor="#FFFFFF"
                android:textAllCaps="false"
                app:cornerRadius="30dp"
                app:elevation="0dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:stateListAnimator="@null"
                android:enabled="false" />

            <!-- Secure Payment Footer -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginTop="24dp"
                android:alpha="0.9">

                <ImageView
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:src="@drawable/ic_privacy_policy"
                    app:tint="#5C5C5C"
                    android:layout_marginEnd="6dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Secured by"
                    android:fontFamily="@font/inter_medium"
                    android:textSize="12sp"
                    android:textColor="#5C5C5C"
                    android:layout_marginEnd="6dp"
                    android:includeFontPadding="false"/>

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_razorpay"
                    android:scaleType="fitCenter"
                    app:tint="#1A1A1A"
                    android:layout_marginEnd="4dp" />
                
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Razorpay"
                    android:fontFamily="@font/inter_bold"
                    android:textSize="12sp"
                    android:textColor="#1A1A1A"
                    android:includeFontPadding="false"/>

            </LinearLayout>
            
            <!-- Bottom Spacer -->
            <View
                android:layout_width="match_parent"
                android:layout_height="24dp"/>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
