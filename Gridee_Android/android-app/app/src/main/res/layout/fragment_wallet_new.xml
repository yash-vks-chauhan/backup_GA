<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_primary"
    android:fitsSystemWindows="false">

    <!-- Sticky Wallet Card Header -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_wallet_balance"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="16dp"
        app:cardCornerRadius="24dp"
        app:cardElevation="12dp"
        app:cardBackgroundColor="@android:color/transparent"
        app:strokeWidth="0.5dp"
        app:strokeColor="#1FFFFFFF"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Gradient Background with Decorative Layer -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/wallet_card_gradient"
            android:clipChildren="true"
            android:clipToPadding="false">

            <!-- Content Layer -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="24dp"
                android:paddingEnd="20dp"
                android:paddingTop="24dp"
                android:paddingBottom="20dp">

            <!-- Label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="BALANCE"
                android:textColor="@android:color/white"
                android:textSize="11sp"
                android:alpha="0.55"
                android:letterSpacing="0.18"
                android:textAllCaps="true"
                android:fontFamily="@font/inter_medium"
                android:includeFontPadding="false" />

            <!-- Balance Hero: coin + whole -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="12dp">

                <TextView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_gridee_coin"
                    android:text="G"
                    android:textColor="#E6FFFFFF"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/inter_bold"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:importantForAccessibility="no"
                    android:layout_marginEnd="12dp" />

                <TextView
                    android:id="@+id/tv_balance_amount"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:maxLines="1"
                    android:text="0"
                    android:textColor="@android:color/white"
                    android:textSize="48sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/inter_bold"
                    android:letterSpacing="-0.035"
                    android:includeFontPadding="false"
                    android:fontFeatureSettings="'tnum' on, 'lnum' on"
                    app:autoSizeTextType="uniform"
                    app:autoSizeMinTextSize="22sp"
                    app:autoSizeMaxTextSize="48sp"
                    app:autoSizeStepGranularity="1sp" />

            </LinearLayout>

            <!-- Gold Hairline Accent -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@drawable/divider_gold_hairline"
                android:layout_marginTop="30dp" />

            <!-- Action Row: Wide Gold Earn Pill + Compact Add Circle -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="18dp">

                <!-- Earn Pill (Hero CTA) -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/btn_watch_ad"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    app:cardCornerRadius="26dp"
                    app:cardElevation="6dp"
                    app:cardBackgroundColor="@android:color/transparent"
                    android:outlineSpotShadowColor="#66C6930A"
                    android:outlineAmbientShadowColor="#33C6930A"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    android:contentDescription="Watch ad to earn coins">

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_gold_pill_earn" />

                    <!-- Metallic gloss overlay (top-half sheen) -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_gold_gloss_overlay" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:layout_gravity="center"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="16dp">

                        <!-- Minimal Diamond / Reward Icon -->
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_reward_watch_claim"
                            app:tint="#FFFFFF" />

                        <!-- Combined Sleek Text -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Earn 10"
                            android:textColor="#FFFFFF"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/inter_bold"
                            android:letterSpacing="0.01"
                            android:includeFontPadding="false"
                            android:layout_marginStart="8dp" />

                        <!-- Gridee Coin Glyph (Wireframe styled to match text) -->
                        <TextView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:background="@drawable/bg_gridee_coin_wire"
                            android:text="G"
                            android:textColor="#FFFFFF"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/inter_bold"
                            android:gravity="center"
                            android:includeFontPadding="false"
                            android:importantForAccessibility="no"
                            android:layout_marginStart="4dp" />

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

                <!-- Add Money Secondary Button -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/btn_add_money"
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:layout_marginStart="12dp"
                    app:cardCornerRadius="26dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="@android:color/transparent"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    android:contentDescription="Add money to wallet">

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_add_money_button" />

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_plus_thin"
                        app:tint="#0A0E13" />

                </androidx.cardview.widget.CardView>

            </LinearLayout>

            </LinearLayout>

        </FrameLayout>

    </com.google.android.material.card.MaterialCardView>

    <!-- Scrollable Content Area with Pull-to-Refresh -->
    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipe_refresh"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/card_wallet_balance"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <androidx.core.widget.NestedScrollView
            android:id="@+id/scroll_content"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:clipToPadding="false"
            android:scrollbars="none"
            android:overScrollMode="ifContentScrolls">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="8dp"
            android:paddingBottom="12dp"
            android:clipChildren="false"
            android:clipToPadding="false">

            <!-- Quick Actions Section Header -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Quick Top-up"
                android:textColor="@color/text_secondary"
                android:textSize="14sp"
                android:textStyle="bold"
                android:fontFamily="@font/inter_bold"
                android:layout_marginStart="24dp"
                android:layout_marginBottom="12dp"
                android:layout_marginTop="24dp" />

            <!-- Floating Glass Chips Quick Top-up -->
            <LinearLayout
                android:id="@+id/layout_quick_add_money"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="12dp"
                android:layout_marginBottom="12dp"
                android:orientation="horizontal"
                android:gravity="center"
                android:padding="4dp"
                android:clipChildren="false"
                android:clipToPadding="false">

                <!-- Chip 1: ₹50 -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btn_quick_add_10"
                    android:layout_width="0dp"
                    android:layout_height="68dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    app:cardCornerRadius="100dp"
                    app:cardElevation="12dp"
                    app:cardBackgroundColor="@android:color/transparent"
                    app:strokeWidth="0dp"
                    app:strokeColor="@android:color/transparent"
                    android:outlineSpotShadowColor="#590F172A"
                    android:outlineAmbientShadowColor="#1F0F172A"
                    android:stateListAnimator="@animator/wallet_chip_state_animator"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_wallet_chip_ceramic"
                        android:gravity="center"
                        android:baselineAligned="false"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:background="@drawable/bg_gridee_coin_dark"
                            android:text="G"
                            android:textColor="@color/btn_text_on_brand"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/inter_bold"
                            android:gravity="center"
                            android:includeFontPadding="false"
                            android:paddingTop="1dp"
                            android:importantForAccessibility="no"
                            android:layout_marginEnd="4dp" />

                        <TextView
                            android:id="@+id/tv_quick_add_50"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="50"
                            android:textColor="@color/text_primary"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/inter_bold" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Chip 2: ₹100 -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btn_quick_add_20"
                    android:layout_width="0dp"
                    android:layout_height="68dp"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="4dp"
                    app:cardCornerRadius="100dp"
                    app:cardElevation="12dp"
                    app:cardBackgroundColor="@android:color/transparent"
                    app:strokeWidth="0dp"
                    app:strokeColor="@android:color/transparent"
                    android:outlineSpotShadowColor="#590F172A"
                    android:outlineAmbientShadowColor="#1F0F172A"
                    android:stateListAnimator="@animator/wallet_chip_state_animator"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_wallet_chip_ceramic"
                        android:gravity="center"
                        android:baselineAligned="false"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:background="@drawable/bg_gridee_coin_dark"
                            android:text="G"
                            android:textColor="@color/btn_text_on_brand"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/inter_bold"
                            android:gravity="center"
                            android:includeFontPadding="false"
                            android:paddingTop="1dp"
                            android:importantForAccessibility="no"
                            android:layout_marginEnd="4dp" />

                        <TextView
                            android:id="@+id/tv_quick_add_100"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="100"
                            android:textColor="@color/text_primary"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/inter_bold" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Chip 3: ₹200 -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btn_quick_add_100"
                    android:layout_width="0dp"
                    android:layout_height="68dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    app:cardCornerRadius="100dp"
                    app:cardElevation="12dp"
                    app:cardBackgroundColor="@android:color/transparent"
                    app:strokeWidth="0dp"
                    app:strokeColor="@android:color/transparent"
                    android:outlineSpotShadowColor="#590F172A"
                    android:outlineAmbientShadowColor="#1F0F172A"
                    android:stateListAnimator="@animator/wallet_chip_state_animator"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_wallet_chip_ceramic"
                        android:gravity="center"
                        android:baselineAligned="false"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:background="@drawable/bg_gridee_coin_dark"
                            android:text="G"
                            android:textColor="@color/btn_text_on_brand"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/inter_bold"
                            android:gravity="center"
                            android:includeFontPadding="false"
                            android:paddingTop="1dp"
                            android:importantForAccessibility="no"
                            android:layout_marginEnd="4dp" />

                        <TextView
                            android:id="@+id/tv_quick_add_200"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="200"
                            android:textColor="@color/text_primary"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/inter_bold" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

            <!-- Activity Section Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Activity"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/inter_bold"
                    android:layout_marginStart="24dp" />

                <LinearLayout
                    android:id="@+id/tv_view_all"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:layout_marginEnd="16dp"
                    android:background="@drawable/bg_pill_hairline_white"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/inter_bold"
                        android:text="View All"
                        android:textAllCaps="false"
                        android:textColor="@color/text_primary"
                        android:textSize="12sp"
                        android:includeFontPadding="false" />

                    <ImageView
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:layout_marginStart="4dp"
                        android:src="@drawable/ic_arrow_right_mini"
                        app:tint="@color/icon_secondary" />

                </LinearLayout>

            </LinearLayout>

            <!-- Transactions List (No Container) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="0dp"
                android:orientation="vertical">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_transactions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    android:clipToPadding="false"
                    tools:listitem="@layout/item_transaction" />

                <!-- Empty State -->
                <LinearLayout
                    android:id="@+id/layout_empty_state"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:visibility="gone"
                    android:padding="32dp">

                    <androidx.compose.ui.platform.ComposeView
                        android:id="@+id/empty_state_animation"
                        android:layout_width="120dp"
                        android:layout_height="120dp"
                        android:layout_marginBottom="12dp" />

                    <TextView
                        android:id="@+id/tv_empty_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="No Transactions"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:id="@+id/tv_empty_subtitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Your recent activity will show up here"
                        android:textSize="14sp"
                        android:textColor="@color/text_tertiary"
                        android:gravity="center" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

        </androidx.core.widget.NestedScrollView>

    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
