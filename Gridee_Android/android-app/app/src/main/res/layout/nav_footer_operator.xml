<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#F3F4F6"
        android:layout_marginBottom="16dp" />

    <!-- Help & Support (Moved to Footer) -->
    <LinearLayout
        android:id="@+id/nav_help_footer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true"
        android:paddingVertical="12dp"
        android:layout_marginBottom="4dp">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_help"
            app:tint="#4B5563"
            android:contentDescription="@string/menu_help" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/menu_help"
            android:fontFamily="@font/inter_medium"
            android:textSize="14sp"
            android:textColor="#374151"
            android:layout_marginStart="16dp" />

    </LinearLayout>

    <!-- Logout Button -->
    <LinearLayout
        android:id="@+id/nav_logout_footer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true"
        android:paddingVertical="12dp">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_logout"
            app:tint="#EF4444" 
            android:contentDescription="@string/menu_logout" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/menu_logout"
            android:fontFamily="@font/inter_medium"
            android:textSize="14sp"
            android:textColor="#EF4444"
            android:layout_marginStart="16dp" />

    </LinearLayout>

    <!-- App Version & Legal -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Gridee Operator • v2.4.0"
        android:fontFamily="@font/inter_regular"
        android:textSize="12sp"
        android:textColor="#9CA3AF"
        android:gravity="center"
        android:layout_marginTop="24dp"
        android:layout_marginBottom="8dp" />



</LinearLayout>
