<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?attr/selectableItemBackground">

    <LinearLayout
        android:id="@+id/contentContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="24dp"
        android:paddingTop="22dp"
        android:paddingEnd="24dp"
        android:paddingBottom="22dp"
        android:gravity="center_vertical"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_location"
            app:tint="@color/text_secondary"
            android:layout_marginEnd="20dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tv_spot_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Spot Name"
                android:textColor="@color/text_primary"
                android:textSize="18sp"
                android:fontFamily="@font/inter_medium" />

            <LinearLayout
                android:id="@+id/layout_availability"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/status_soft_active"
                android:paddingHorizontal="10dp"
                android:paddingVertical="6dp"
                android:layout_marginTop="6dp">

                <View
                    android:id="@+id/view_status_dot"
                    android:layout_width="6dp"
                    android:layout_height="6dp"
                    android:background="@drawable/bg_dot_inactive"
                    android:backgroundTint="@color/parking_spot_available"
                    android:layout_marginEnd="6dp" />

                <TextView
                    android:id="@+id/tv_availability"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0/0 Available"
                    android:textColor="@color/parking_spot_available"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/inter_semibold" />
            </LinearLayout>

        </LinearLayout>

        <RadioButton
            android:id="@+id/rb_select_spot"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:buttonTint="@color/selector_radio_vehicle_clean"
            app:buttonTint="@color/selector_radio_vehicle_clean"
            android:clickable="false"
            android:focusable="false" />

    </LinearLayout>

    <View
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:layout_marginStart="76dp"
        android:layout_marginEnd="24dp"
        android:background="@color/background_primary"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
