<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/rootContainer"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_primary"
    android:fitsSystemWindows="true"
    tools:context=".ui.auth.WelcomeActivity">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp">

        <TextView
            android:id="@+id/tvBrand"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/welcome_brand_margin_top"
            android:text="@string/app_name"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/welcome_brand_text_size"
            android:fontFamily="@font/inter_bold"
            android:textStyle="bold"
            android:letterSpacing="-0.05"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tvHeadline"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/welcome_headline_margin_top"
            android:letterSpacing="-0.01"
            android:lineSpacingExtra="4dp"
            android:text="Park smarter,\nsave time,\nreduce congestion."
            android:textAlignment="viewStart"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/welcome_headline_text_size"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvBrand" />

        <TextView
            android:id="@+id/tvSubheadline"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/welcome_subheadline_margin_top"
            android:text="The easiest way to find and book parking spots in SRM."
            android:textColor="@color/text_secondary"
            android:textSize="@dimen/welcome_subheadline_text_size"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvHeadline" />

        <LinearLayout
            android:id="@+id/layoutActions"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/welcome_actions_margin_top"
            android:layout_marginBottom="24dp"
            android:orientation="vertical"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvSubheadline"
            app:layout_constraintVertical_bias="1.0">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSignUpEmail"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:fontFamily="@font/inter_semibold"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:stateListAnimator="@null"
                android:text="Create account with email"
                android:textAllCaps="false"
                android:textColor="@color/md3_on_primary"
                android:textSize="16sp"
                app:backgroundTint="@color/brand_primary"
                app:cornerRadius="28dp"
                app:elevation="0dp"
                app:icon="@drawable/ic_email_outlined"
                app:iconGravity="textStart"
                app:iconPadding="12dp"
                app:iconTint="@color/md3_on_primary" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="24dp">
                
                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="@color/divider" />

                <TextView
                    android:id="@+id/tvOr"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp"
                    android:text="or"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="@color/divider" />
            </LinearLayout>

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="56dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnContinueWithGoogle"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:fontFamily="@font/inter_semibold"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:stateListAnimator="@null"
                    android:text="Continue with Google"
                    android:textAllCaps="false"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    app:backgroundTint="@color/background_secondary"
                    app:cornerRadius="28dp"
                    app:elevation="0dp"
                    app:icon="@drawable/ic_google"
                    app:iconGravity="textStart"
                    app:iconPadding="12dp"
                    app:iconTint="@null"
                    app:strokeColor="@color/divider"
                    app:strokeWidth="1dp" />

                <ProgressBar
                    android:id="@+id/progressGoogle"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center"
                    android:indeterminateTint="@color/text_primary"
                    android:visibility="gone" />
            </FrameLayout>

            <TextView
                android:id="@+id/tvTerms"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:gravity="center"
                android:lineSpacingExtra="2dp"
                android:text="By signing up, you agree to our Terms, Privacy Policy, and Data Safety."
                android:textColor="@color/text_tertiary"
                android:textSize="12sp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="@dimen/welcome_login_margin_top"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Already have an account?"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnLogin"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="Log in"
                    android:textAllCaps="false"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    app:cornerRadius="20dp"
                    app:rippleColor="#0D000000" />
            </LinearLayout>
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

    </ScrollView>

    <!-- Loading Overlay -->
    <View
        android:id="@+id/loadingScrim"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/background_primary"
        android:alpha="0"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/loadingContent"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:gravity="center"
        android:orientation="vertical"
        android:alpha="0"
        android:visibility="gone">

        <ProgressBar
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:indeterminateTint="@color/text_primary"
            style="?android:attr/progressBarStyle" />

        <TextView
            android:id="@+id/tvLoadingMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Signing in..."
            android:textColor="@color/text_secondary"
            android:textSize="15sp"
            android:fontFamily="@font/inter_regular"
            android:letterSpacing="0.01" />

    </LinearLayout>

</FrameLayout>
