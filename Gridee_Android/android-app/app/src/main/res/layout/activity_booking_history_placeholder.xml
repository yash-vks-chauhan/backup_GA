<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_primary"
    android:fitsSystemWindows="true"
    tools:context=".ui.profile.BookingHistoryPlaceholderActivity">

    <!-- Scrollable content — full-bleed, scrolls behind the frosted toolbar -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/scroll_content"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:scrollbars="none"
        android:clipToPadding="false">

        <FrameLayout
            android:id="@+id/content_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- Booking History List (no card — editorial list feel) -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_booking_history"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clipToPadding="false"
                android:layoutAnimation="@anim/layout_animation_waterfall"
                android:nestedScrollingEnabled="false"
                android:paddingTop="4dp"
                android:paddingBottom="32dp"
                android:scrollbars="none"
                tools:listitem="@layout/item_booking_history" />

            <!-- Empty State -->
            <LinearLayout
                android:id="@+id/layout_empty_state"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:visibility="gone"
                android:paddingHorizontal="48dp"
                android:layout_marginTop="120dp">

                <ImageView
                    android:id="@+id/iv_empty_state"
                    android:layout_width="180dp"
                    android:layout_height="180dp"
                    android:src="@drawable/ic_booking_history_ticket"
                    app:tint="#E5E7EB"
                    android:layout_marginBottom="28dp"
                    android:contentDescription="No booking history" />

                <TextView
                    android:id="@+id/tv_empty_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="No booking history yet"
                    android:textSize="22sp"
                    android:textColor="@color/text_primary"
                    android:letterSpacing="-0.01"
                    android:fontFamily="@font/inter_bold"
                    android:textAlignment="center"
                    android:layout_marginBottom="10dp" />

                <TextView
                    android:id="@+id/tv_empty_subtitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:maxWidth="320dp"
                    android:text="Completed or cancelled bookings will appear here."
                    android:textSize="16sp"
                    android:textColor="@color/text_tertiary"
                    android:fontFamily="@font/inter_medium"
                    android:gravity="center"
                    android:textAlignment="center"
                    android:lineSpacingMultiplier="1.3" />

            </LinearLayout>

            <!-- Loading Spinner -->
            <ProgressBar
                android:id="@+id/progress_loading"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:visibility="gone"
                android:indeterminateTint="@color/primary" />

        </FrameLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- Unified frosted header overlay — gradient from opaque at top to transparent at bottom.
         Drawn AFTER the scroll view so it renders ON TOP (same pattern as Profile page). -->
    <View
        android:id="@+id/view_toolbar_frost"
        android:layout_width="match_parent"
        android:layout_height="112dp"
        android:layout_gravity="top"
        android:background="@drawable/bg_toolbar_frosted"
        android:alpha="0" />

    <!-- Toolbar header — floats on top of everything -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layout_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:paddingHorizontal="20dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btn_back"
            style="@style/Widget.Gridee.BackButton.IOS26"
            android:layout_width="@dimen/ios26_back_button_size"
            android:layout_height="@dimen/ios26_back_button_size"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <ImageView
                android:layout_width="@dimen/ios26_back_icon_size"
                android:layout_height="@dimen/ios26_back_icon_size"
                android:layout_gravity="center"
                android:contentDescription="@string/back"
                android:src="@drawable/ic_arrow_back"
                app:tint="@color/brand_primary" />
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/tv_header_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Booking History"
            android:textColor="@color/text_primary"
            android:textSize="20sp"
            android:textStyle="bold"
            android:fontFamily="@font/inter_bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
