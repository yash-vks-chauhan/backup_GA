<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/menu_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    android:orientation="vertical"
    android:fitsSystemWindows="true">

    <!-- Header Area -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="24dp"
        android:paddingHorizontal="24dp"
        android:paddingBottom="24dp">
        
        <!-- Branding -->
        <TextView
            android:id="@+id/tv_menu_brand"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Operator Menu"
            android:textSize="20sp"
            android:textColor="#111827"
            android:textStyle="bold"
            android:fontFamily="@font/inter_bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <!-- Close Button (X) -->
        <FrameLayout
            android:id="@+id/btn_close_menu"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">
            
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_close"
                app:tint="#6B7280" />
        </FrameLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Scrollable Menu Items -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingBottom="24dp">

            <!-- Profile Section (Centered, No Card Container) -->
            <LinearLayout
                android:id="@+id/card_menu_profile"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingTop="24dp"
                android:paddingBottom="24dp"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true">

                <!-- Master Identity Container (Holds Avatar + Floating Badge) -->
                <FrameLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:clipChildren="false"
                    android:clipToPadding="false">

                    <!-- Avatar Card -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="104dp"
                        android:layout_height="104dp"
                        android:layout_margin="8dp"
                        app:cardCornerRadius="52dp"
                        app:cardElevation="10dp"
                        app:cardMaxElevation="12dp"
                        app:cardPreventCornerOverlap="false"
                        app:cardBackgroundColor="#FFFFFF">

                        <!-- Inner Container for White Border -->
                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_margin="5dp">

                            <FrameLayout
                                android:id="@+id/card_menu_avatar_container"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@drawable/circle_background_green">

                                <TextView
                                    android:id="@+id/tv_menu_initials"
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:text="O"
                                    android:textColor="#FFFFFF"
                                    android:textSize="36sp"
                                    android:textStyle="bold"
                                    android:gravity="center"
                                    android:fontFamily="@font/inter_bold" />

                            </FrameLayout>
                        </FrameLayout>

                    </androidx.cardview.widget.CardView>

                    <!-- Floating Badge -->
                    <FrameLayout
                        android:layout_width="34dp"
                        android:layout_height="34dp"
                        android:layout_gravity="bottom|end"
                        android:layout_marginEnd="4dp"
                        android:layout_marginBottom="4dp"
                        android:background="@drawable/bg_badge_circle_border"
                        android:clickable="false"
                        android:focusable="false"
                        android:elevation="12dp">

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_edit_profile"
                            app:tint="#FFFFFF"
                            android:importantForAccessibility="no" />

                    </FrameLayout>

                </FrameLayout>

                <!-- Name -->
                <TextView
                    android:id="@+id/tv_menu_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Operator"
                    android:textColor="#111827"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/inter_bold"
                    android:layout_marginTop="20dp"
                    android:letterSpacing="0.01" />

            </LinearLayout>

            <!-- Section: Manage -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="General"
                android:textColor="#6B7280"
                android:textSize="14sp"
                android:textStyle="bold"
                android:fontFamily="@font/inter_bold"
                android:layout_marginStart="8dp"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="8dp" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="28dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- History -->
                    <LinearLayout
                        android:id="@+id/btn_menu_history"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="20dp"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true">
                        <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_history_doc" app:tint="#6B7280" android:layout_marginEnd="16dp" />
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="History" android:textColor="#111827" android:textSize="16sp" android:fontFamily="@font/inter_medium" />
                        <ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@drawable/ic_chevron_right" app:tint="#6B7280" />
                    </LinearLayout>
                    
                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F3F4F6" android:layout_marginStart="60dp" />

                    <!-- Settings -->
                     <LinearLayout
                        android:id="@+id/btn_menu_settings"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="20dp"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true">
                        <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_settings_enhanced" app:tint="#6B7280" android:layout_marginEnd="16dp" />
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Settings" android:textColor="#111827" android:textSize="16sp" android:fontFamily="@font/inter_medium" />
                        <ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@drawable/ic_chevron_right" app:tint="#6B7280" />
                    </LinearLayout>

                     <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F3F4F6" android:layout_marginStart="60dp" />

                    <!-- Language -->
                    <LinearLayout
                        android:id="@+id/btn_menu_language"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="20dp"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true">
                        <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_language" app:tint="#6B7280" android:layout_marginEnd="16dp" />
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Language" android:textColor="#111827" android:textSize="16sp" android:fontFamily="@font/inter_medium" />
                        <TextView android:id="@+id/tv_current_lang" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="English" android:textColor="#9CA3AF" android:textSize="12sp" android:fontFamily="@font/inter_regular" android:layout_marginEnd="8dp"/>
                        <ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@drawable/ic_chevron_right" app:tint="#6B7280" />
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>


            <!-- Section: Support -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Support"
                android:textColor="#6B7280"
                android:textSize="14sp"
                android:textStyle="bold"
                android:fontFamily="@font/inter_bold"
                android:layout_marginStart="8dp"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="8dp" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="28dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Help -->
                     <LinearLayout
                        android:id="@+id/btn_menu_help"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="20dp"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true">
                        <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_help" app:tint="#6B7280" android:layout_marginEnd="16dp" />
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Help &amp; Support" android:textColor="#111827" android:textSize="16sp" android:fontFamily="@font/inter_medium" />
                        <ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@drawable/ic_chevron_right" app:tint="#6B7280" />
                    </LinearLayout>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Logout -->
             <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="28dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FEF2F2"
                android:layout_marginTop="8dp">

                <LinearLayout
                    android:id="@+id/btn_menu_logout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="20dp"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true">
                    
                    <ImageView 
                        android:layout_width="24dp" 
                        android:layout_height="24dp" 
                        android:src="@drawable/ic_logout" 
                        app:tint="#EF4444" 
                        android:layout_marginEnd="16dp" />
                        
                    <TextView 
                        android:layout_width="0dp" 
                        android:layout_height="wrap_content" 
                        android:layout_weight="1" 
                        android:text="Log Out" 
                        android:textColor="#EF4444" 
                        android:textSize="16sp" 
                        android:fontFamily="@font/inter_bold" />
                        
                </LinearLayout>

            </androidx.cardview.widget.CardView>

             <!-- Version -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="v2.4.0 • Gridee Operator"
                android:textColor="#D1D5DB"
                android:textSize="11sp"
                android:fontFamily="@font/inter_medium"
                android:gravity="center"
                android:layout_marginTop="24dp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>
