<com.gridee.parking.ui.views.TicketView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/card_booking_active"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="24dp"
    android:layout_marginVertical="24dp"
    app:cardBackgroundColor="@android:color/white"
    app:cardCornerRadius="28dp"
    app:cardElevation="24dp"
    app:strokeColor="#FFFFFF"
    app:strokeWidth="0dp"
    app:rippleColor="#10000000"
    android:outlineAmbientShadowColor="#3364748B"
    android:outlineSpotShadowColor="#26000000"
    tools:targetApi="p"
    android:clickable="true"
    android:focusable="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_card_surface_gradient"
        android:paddingBottom="28dp">

        <!-- Top Section: Main Info -->
        <LinearLayout
            android:id="@+id/layout_top_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="28dp"
            android:paddingTop="36dp"
            android:paddingBottom="42dp"
            app:layout_constraintTop_toTopOf="parent">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="32dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="@drawable/bg_status_pill_live"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="6dp"
                        android:layout_marginBottom="12dp">

                        <FrameLayout
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:layout_marginEnd="6dp">

                            <!-- The Ripple (Expands) -->
                            <View
                                android:id="@+id/view_live_ripple"
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:layout_gravity="center"
                                android:background="@drawable/shape_circle_green_faint" />

                            <!-- The Core (Solid) -->
                            <View
                                android:id="@+id/view_live_core"
                                android:layout_width="6dp"
                                android:layout_height="6dp"
                                android:layout_gravity="center"
                                android:background="@drawable/shape_status_dot_active" />
                        </FrameLayout>

                        <TextView
                            android:id="@+id/status_badge"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="LIVE SESSION"
                            android:textSize="11sp"
                            android:textColor="#059669"
                            android:textStyle="bold"
                            android:fontFamily="@font/inter_bold"
                            android:letterSpacing="0.05" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="4dp">

                        <TextView
                            android:id="@+id/tv_parking_spot"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Spot A-15"
                            android:textSize="32sp"
                            android:textColor="#111827"
                            android:fontFamily="@font/inter_bold"
                            android:textStyle="bold"
                            android:letterSpacing="-0.03"/>
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tv_location_sub"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Phoenix Mall, Pune"
                        android:textSize="14sp"
                        android:textColor="#6B7280"
                        android:fontFamily="@font/inter_medium"/>
                </LinearLayout>

                </LinearLayout>


            <!-- Vehicle Info Moved to Footer -->

            <!-- Time Row (The Hero) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:id="@+id/tv_check_in_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="10:00 AM"
                    android:textSize="28sp"
                    android:textColor="#111827"
                    android:fontFamily="@font/inter_bold"
                    android:textStyle="bold"
                    android:letterSpacing="-0.03"/>

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_arrow_right"
                    app:tint="#9CA3AF"
                    android:layout_marginHorizontal="12dp" />

                <TextView
                    android:id="@+id/tv_check_out_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="12:00 PM"
                    android:textSize="28sp"
                    android:textColor="#111827"
                    android:fontFamily="@font/inter_bold"
                    android:textStyle="bold"
                    android:letterSpacing="-0.03"/>
            </LinearLayout>
            
            <!-- Vehicle Info Moved Up -->

            <!-- Progress & Remaining -->
            <ProgressBar
                android:id="@+id/progress_time"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="4dp"
                android:layout_marginTop="32dp"
                android:progressDrawable="@drawable/progress_active_timer"
                android:progress="45" />

            <TextView
                android:id="@+id/tv_time_remaining"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="45m remaining"
                android:textSize="12sp"
                android:textColor="#059669"
                android:fontFamily="@font/inter_bold"
                android:layout_gravity="end"
                android:layout_marginTop="8dp"/>

        </LinearLayout>

        <!-- Ticket Cutout Divider Section (Refined: No Fake Notches) -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/layout_cutout"
            android:layout_width="match_parent"
            android:layout_height="2dp"
            app:layout_constraintTop_toBottomOf="@id/layout_top_content">

            <View
                android:id="@+id/divider_dashed"
                android:layout_width="match_parent"
                android:layout_height="2dp"
                android:background="@drawable/bg_dashed_divider"
                android:layerType="software"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Bottom Section: Footer Details & Actions -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="28dp"
            android:paddingVertical="24dp" 
            app:layout_constraintTop_toBottomOf="@id/layout_cutout">

            <!-- Primary Info Row (Date & Amount) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="28dp">
                
                <!-- Date Section -->
                <!-- Date/Vehicle Section -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <!-- Vehicle Row -->
                     <LinearLayout
                         android:layout_width="wrap_content"
                         android:layout_height="wrap_content"
                         android:orientation="vertical"
                         android:gravity="start">
                         
                         <TextView
                             android:layout_width="wrap_content"
                             android:layout_height="wrap_content"
                             android:text="VEHICLE"
                             android:textSize="11sp"
                             android:textColor="#6B7280"
                             android:fontFamily="@font/inter_bold"
                             android:letterSpacing="0.05"
                             android:layout_marginBottom="2dp"/>
                         
                         <TextView
                             android:id="@+id/tv_vehicle_number"
                             android:layout_width="wrap_content"
                             android:layout_height="wrap_content"
                             android:text="MH 12 AB 1234"
                             android:textSize="20sp"
                             android:textColor="#111827"
                             android:fontFamily="@font/inter_bold"
                             android:letterSpacing="-0.02"/>
                     </LinearLayout>


                </LinearLayout>

                <!-- Amount Section -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="end">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="TOTAL"
                        android:textSize="11sp"
                        android:textColor="#6B7280"
                        android:fontFamily="@font/inter_bold"
                        android:letterSpacing="0.05"
                        android:layout_marginBottom="2dp"/>

                    <TextView
                        android:id="@+id/tv_amount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="₹150.00"
                        android:textSize="20sp"
                        android:textColor="#111827"
                        android:fontFamily="@font/inter_bold"
                        android:letterSpacing="-0.02"/>
                    
                    <TextView
                        android:id="@+id/tv_booking_date"
                         android:layout_width="wrap_content"
                         android:layout_height="wrap_content"
                         android:text="Oct 24, 2025"
                         android:textSize="13sp"
                         android:fontFamily="@font/inter_medium"
                         android:textColor="#6B7280"
                         android:layout_marginTop="0dp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Action Buttons Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_navigate"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:text="Navigate"
                    android:textColor="#4B5563"
                    android:textSize="14sp"
                    android:letterSpacing="0.02"
                    android:fontFamily="@font/inter_medium"
                    app:icon="@drawable/ic_map_folded"
                    app:iconSize="20dp"
                    app:iconTint="#4B5563"
                    app:rippleColor="#10000000"
                    app:cornerRadius="28dp"
                    android:layout_marginEnd="4dp" />
                    
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_extend"
                    style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:text="Extend"
                    android:textSize="14sp"
                    android:letterSpacing="0.02"
                    android:textColor="#FFFFFF"
                    android:fontFamily="@font/inter_medium"
                    android:backgroundTint="#111827"
                    app:icon="@drawable/ic_time_extend_custom"
                    app:iconSize="20dp"
                    app:iconTint="#FFFFFF"
                    app:cornerRadius="28dp"
                    android:layout_marginStart="4dp" />
                    
            </LinearLayout>
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.gridee.parking.ui.views.TicketView>
