<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Status bar height for proper spacing -->
    <dimen name="status_bar_height">32dp</dimen>
    
    <!-- General spacing -->
    <dimen name="margin_small">8dp</dimen>
    <dimen name="margin_medium">16dp</dimen>
    <dimen name="margin_large">24dp</dimen>
    
    <!-- Card spacing -->
    <dimen name="card_margin">12dp</dimen>
    <dimen name="card_corner_radius">12dp</dimen>
    
    <!-- Button dimensions -->
    <dimen name="button_height">48dp</dimen>
    <dimen name="button_corner_radius">8dp</dimen>

    <!-- Segmented control sizing -->
    <dimen name="segmented_control_height">56dp</dimen>
    <dimen name="segmented_control_padding">6dp</dimen>
    <dimen name="segmented_control_item_padding">16dp</dimen>

    <!-- Transaction header animation - Enhanced for smoother professional transitions -->
    <dimen name="transaction_header_collapse_range">48dp</dimen>
    <dimen name="transaction_header_padding_reduction">6dp</dimen>
    <dimen name="transaction_header_title_horizontal_shift">2dp</dimen>
    <dimen name="transaction_header_count_spacing">6dp</dimen>
    <dimen name="transaction_header_filter_collapsed_spacing">8dp</dimen>

    <!-- Close button dimensions -->
    <dimen name="close_button_size">52dp</dimen>
    <dimen name="close_button_radius">26dp</dimen>
    <dimen name="close_button_elevation">4dp</dimen>
    <dimen name="close_button_top_margin">16dp</dimen>
    <dimen name="close_button_bottom_margin">16dp</dimen>
    <dimen name="close_icon_size">22dp</dimen>

    <!-- iOS 26 inspired back button dimensions -->
    <dimen name="ios26_back_button_size">44dp</dimen>
    <dimen name="ios26_back_button_radius">22dp</dimen>
    <dimen name="ios26_back_button_elevation">2dp</dimen>
    <dimen name="ios26_back_button_stroke_width">0dp</dimen>
    <dimen name="ios26_back_icon_size">20dp</dimen>

    <!-- Edit Profile Input Field Outline -->
    <dimen name="profile_input_outline_width">1dp</dimen>

    <!-- Welcome/onboarding responsive sizing.
         These DEFAULT values are the COMPACT set, used on phones narrower than 400dp
         (e.g. 360dp Galaxy S23-class) so the headline doesn't push the Log-in link
         below the fold. Larger phones (>=400dp, incl. the A54 at 411dp) get the
         original sizes from values-sw400dp/dimens.xml. -->
    <dimen name="welcome_brand_text_size">38sp</dimen>
    <dimen name="welcome_headline_text_size">33sp</dimen>
    <dimen name="welcome_subheadline_text_size">18sp</dimen>
    <dimen name="welcome_brand_margin_top">16dp</dimen>
    <dimen name="welcome_headline_margin_top">28dp</dimen>
    <dimen name="welcome_subheadline_margin_top">16dp</dimen>
    <dimen name="welcome_actions_margin_top">32dp</dimen>
    <dimen name="welcome_login_margin_top">28dp</dimen>

    <!-- Registration/create-account responsive sizing (COMPACT default for <400dp phones,
         so the 5 fields + Log-in link fit without scrolling). sw400dp restores originals. -->
    <dimen name="reg_title_text_size">28sp</dimen>
    <dimen name="reg_title_margin_top">28dp</dimen>
    <dimen name="reg_first_field_margin_top">24dp</dimen>
    <dimen name="reg_field_gap">12dp</dimen>
    <dimen name="reg_button_margin_top">20dp</dimen>
    <dimen name="reg_login_margin_top">16dp</dimen>
</resources>
