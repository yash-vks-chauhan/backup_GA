<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- 1. Base Shadow (depth on dark surface) -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#000000"/>
            <corners android:radius="100dp"/>
        </shape>
    </item>

    <!-- 2. Main Body -->
    <item android:bottom="3dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:startColor="#2C2C2E"
                android:endColor="#1C1C1E"
                android:type="linear"/>
            <corners android:radius="100dp"/>
        </shape>
    </item>

    <!-- 3. Subtle Specular Highlight -->
    <item android:bottom="3dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:startColor="#14FFFFFF"
                android:endColor="#00FFFFFF"
                android:centerY="0.5"
                android:type="linear"/>
            <corners android:radius="100dp"/>
            <stroke android:width="0.5dp" android:color="#1AFFFFFF"/>
        </shape>
    </item>

</layer-list>