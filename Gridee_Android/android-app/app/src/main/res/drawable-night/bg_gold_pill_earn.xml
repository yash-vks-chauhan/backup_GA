<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <item>
        <shape android:shape="rectangle">
            <solid android:color="#1FC6930A" />
            <corners android:radius="26dp" />
        </shape>
    </item>

    <item
        android:top="1dp"
        android:bottom="1dp"
        android:left="1dp"
        android:right="1dp">
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="135"
                android:startColor="#E0A73B"
                android:centerColor="#B07A10"
                android:endColor="#5E3E00" />
            <corners android:radius="25dp" />
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">
            <stroke
                android:width="0.5dp"
                android:color="#66FFFFFF" />
            <corners android:radius="26dp" />
        </shape>
    </item>

</layer-list>
