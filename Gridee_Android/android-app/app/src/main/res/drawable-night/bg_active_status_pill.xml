<?xml version="1.0" encoding="utf-8"?>
<!--
  Dark-mode LIVE pill. Mirrors the light variant (mint bg + translucent
  green border) but inverted for the dark surface — same brand language,
  just flipped tonally so the pill reads as "soft glow" rather than
  "bright sticker on a dark card".
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="#0D2318" />
    <stroke
        android:width="1dp"
        android:color="#5230D158" />
    <corners android:radius="100dp" />
</shape>
