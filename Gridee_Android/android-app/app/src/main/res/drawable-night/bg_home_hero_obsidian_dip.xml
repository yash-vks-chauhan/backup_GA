<?xml version="1.0" encoding="utf-8"?>
<!-- Obsidian dip (dark mode): a deep navy that fades to PURE #000000 at the bottom,
     so it dissolves into the black body exactly like the light variant melts into
     #F5F5F5. No radial "top glow" overlay here — with its 800dp radius it never
     reached transparency inside the hero, so it washed a faint grey over the whole
     view and left the bottom slightly above pure black (a visible seam against the
     #000000 body). Single shape + dither = clean, seam-free, no OLED banding. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle"
    android:dither="true">
    <gradient
        android:angle="270"
        android:startColor="#222C46"
        android:centerColor="#161D2E"
        android:endColor="#000000"
        android:type="linear" />
</shape>
