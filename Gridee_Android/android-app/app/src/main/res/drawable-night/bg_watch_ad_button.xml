<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <item>
        <shape android:shape="oval">
            <gradient
                android:type="linear"
                android:angle="135"
                android:startColor="#E0A73B"
                android:centerColor="#B07A10"
                android:endColor="#6A4200" />
        </shape>
    </item>

    <item>
        <shape android:shape="oval">
            <stroke
                android:width="0.5dp"
                android:color="#40FFFFFF" />
        </shape>
    </item>

</layer-list>
