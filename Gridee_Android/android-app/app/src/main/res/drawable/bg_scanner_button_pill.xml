<?xml version="1.0" encoding="utf-8"?>
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="@color/scanner_glass_highlight">

    <item>
        <layer-list>
            <item
                android:left="1dp"
                android:top="3dp"
                android:right="1dp"
                android:bottom="1dp">
                <shape android:shape="rectangle">
                    <solid android:color="@color/scanner_glass_shadow" />
                    <corners android:radius="100dp" />
                </shape>
            </item>

            <item>
                <shape android:shape="rectangle">
                    <solid android:color="@color/scanner_glass_surface" />
                    <stroke
                        android:width="1dp"
                        android:color="@color/scanner_glass_border" />
                    <corners android:radius="100dp" />
                </shape>
            </item>

            <item android:top="1dp">
                <shape android:shape="rectangle">
                    <gradient
                        android:angle="270"
                        android:startColor="@color/scanner_glass_highlight"
                        android:endColor="@android:color/transparent" />
                    <corners android:radius="100dp" />
                </shape>
            </item>
        </layer-list>
    </item>
</ripple>
