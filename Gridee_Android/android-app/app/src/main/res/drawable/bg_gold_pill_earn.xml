<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Outer soft gold halo -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#14C6930A" />
            <corners android:radius="26dp" />
        </shape>
    </item>

    <!-- Main gold gradient body, inset 1dp so the halo shows -->
    <item
        android:top="1dp"
        android:bottom="1dp"
        android:left="1dp"
        android:right="1dp">
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="135"
                android:startColor="#F5C04E"
                android:centerColor="#D99A1F"
                android:endColor="#8B5E00" />
            <corners android:radius="25dp" />
        </shape>
    </item>

    <!-- Hairline inner highlight for glass-like edge -->
    <item>
        <shape android:shape="rectangle">
            <stroke
                android:width="0.5dp"
                android:color="#59FFFFFF" />
            <corners android:radius="26dp" />
        </shape>
    </item>

</layer-list>
