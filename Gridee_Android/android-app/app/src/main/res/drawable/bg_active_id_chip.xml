<?xml version="1.0" encoding="utf-8"?>
<!--
  Booking-ID chip pinned at the bottom of the QR stub — the small "serial
  number" that finishes the ticket. Discrete, monospace-style, sits below
  the QR like a real ticket's reference number.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="@android:color/transparent" />
    <stroke
        android:width="1dp"
        android:color="@color/border_light" />
    <corners android:radius="100dp" />
</shape>
