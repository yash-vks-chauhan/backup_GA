<?xml version="1.0" encoding="utf-8"?>
<!--
  Bottom fade gradient — content gracefully dissolves into the page background
  as it approaches the floating navbar. Used by activity_main_container.xml as
  the background of a thin View pinned to the bottom of the screen.

  Direction: transparent at the top, solid `background_primary` at the bottom.
  Angle 90° in Android gradient drawables means bottom→top in the START→END
  direction, so startColor sits at the bottom and endColor sits at the top.

  Auto-themes: background_primary and its transparent variant are defined for
  both values and values-night, so the gradient ends at the page color in
  either mode — content fades to seamless rather than to a defined surface.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <gradient
        android:angle="90"
        android:startColor="@color/background_primary"
        android:endColor="@color/background_primary_transparent"
        android:type="linear" />

</shape>
