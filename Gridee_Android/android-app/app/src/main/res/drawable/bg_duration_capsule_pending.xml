<?xml version="1.0" encoding="utf-8"?>
<!--
  Soft amber pill that floats on the journey rail to call out the session
  length ("4h 0m") at a glance. Sized as a small chip — important enough
  to read, quiet enough to never compete with the times themselves.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="#FFFBEB" />
    <stroke
        android:width="1dp"
        android:color="#33D97706" />
    <corners android:radius="100dp" />
</shape>
