<?xml version="1.0" encoding="utf-8"?>
<!--
  Soft tinted plate behind the bottom "Show at exit" QR action. Reads as
  a pressable chip-button: outlined hairline, gentle background. Mirrors
  the booking-card QR-frame language so the visual vocabulary stays
  consistent across pass states.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="@color/background_primary" />
    <stroke
        android:width="1dp"
        android:color="@color/border_light" />
    <corners android:radius="20dp" />
</shape>
