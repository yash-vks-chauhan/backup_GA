<?xml version="1.0" encoding="utf-8"?>
<!--
  iOS-style tab bar background: clean opaque surface + a single hairline separator.
  No gradient, no shadow band, no floating "shadow" that reads as a grey strip —
  Apple's tab bars use just material + hairline. Cleanest, most professional look.
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Opaque surface -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#FFFFFF" />
        </shape>
    </item>

    <!-- iOS-style separator hairline at the top edge (the only visual delimiter). -->
    <item android:gravity="top">
        <shape android:shape="rectangle">
            <size android:height="0.5dp" />
            <solid android:color="#1F000000" />
        </shape>
    </item>

</layer-list>
