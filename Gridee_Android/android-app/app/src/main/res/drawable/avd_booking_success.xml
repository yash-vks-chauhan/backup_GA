<?xml version="1.0" encoding="utf-8"?>
<animated-vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt">

    <aapt:attr name="android:drawable">
        <vector
            android:width="80dp"
            android:height="80dp"
            android:viewportWidth="80"
            android:viewportHeight="80">

            <!-- Circle outline -->
            <group
                android:name="circleGroup"
                android:pivotX="40"
                android:pivotY="40">
                <path
                    android:name="circle"
                    android:pathData="M40,4 A36,36 0 1,1 39.99,4"
                    android:strokeColor="#10B981"
                    android:strokeWidth="4"
                    android:strokeLineCap="round"
                    android:fillColor="@android:color/transparent"
                    android:trimPathEnd="0" />
            </group>

            <!-- Checkmark stroke -->
            <group android:name="checkGroup">
                <path
                    android:name="check"
                    android:pathData="M24,42 L35,53 L56,28"
                    android:strokeColor="#10B981"
                    android:strokeWidth="4.5"
                    android:strokeLineCap="round"
                    android:strokeLineJoin="round"
                    android:fillColor="@android:color/transparent"
                    android:trimPathEnd="0" />
            </group>

        </vector>
    </aapt:attr>

    <!-- Circle draws in: 0ms to 500ms -->
    <target android:name="circle">
        <aapt:attr name="android:animation">
            <objectAnimator
                android:propertyName="trimPathEnd"
                android:valueFrom="0"
                android:valueTo="1"
                android:duration="500"
                android:startOffset="0"
                android:interpolator="@android:interpolator/decelerate_quad" />
        </aapt:attr>
    </target>

    <!-- Checkmark draws in: 400ms to 700ms (overlaps slightly with circle end) -->
    <target android:name="check">
        <aapt:attr name="android:animation">
            <objectAnimator
                android:propertyName="trimPathEnd"
                android:valueFrom="0"
                android:valueTo="1"
                android:duration="350"
                android:startOffset="400"
                android:interpolator="@android:interpolator/decelerate_quad" />
        </aapt:attr>
    </target>

    <!-- Circle group scale bounce: starts at 500ms -->
    <target android:name="circleGroup">
        <aapt:attr name="android:animation">
            <set android:ordering="sequentially">
                <!-- Wait for circle to finish drawing -->
                <objectAnimator
                    android:propertyName="scaleX"
                    android:valueFrom="1"
                    android:valueTo="1"
                    android:duration="500" />
                <!-- Bounce out -->
                <objectAnimator
                    android:propertyName="scaleX"
                    android:valueFrom="1"
                    android:valueTo="1.08"
                    android:duration="120"
                    android:interpolator="@android:interpolator/accelerate_decelerate" />
                <!-- Bounce back -->
                <objectAnimator
                    android:propertyName="scaleX"
                    android:valueFrom="1.08"
                    android:valueTo="1"
                    android:duration="150"
                    android:interpolator="@android:interpolator/decelerate_quad" />
            </set>
        </aapt:attr>
    </target>

    <!-- Match Y scale with X -->
    <target android:name="circleGroup">
        <aapt:attr name="android:animation">
            <set android:ordering="sequentially">
                <objectAnimator
                    android:propertyName="scaleY"
                    android:valueFrom="1"
                    android:valueTo="1"
                    android:duration="500" />
                <objectAnimator
                    android:propertyName="scaleY"
                    android:valueFrom="1"
                    android:valueTo="1.08"
                    android:duration="120"
                    android:interpolator="@android:interpolator/accelerate_decelerate" />
                <objectAnimator
                    android:propertyName="scaleY"
                    android:valueFrom="1.08"
                    android:valueTo="1"
                    android:duration="150"
                    android:interpolator="@android:interpolator/decelerate_quad" />
            </set>
        </aapt:attr>
    </target>

</animated-vector>
