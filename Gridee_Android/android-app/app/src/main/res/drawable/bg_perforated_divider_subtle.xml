<?xml version="1.0" encoding="utf-8"?>
<!--
  Tighter, lower-contrast variant of bg_dashed_divider. Used inside the
  hero card to separate the journey body from the footer (vehicle / amount
  row) — a quiet "ticket stub" cue rather than a hard rule.
  Requires android:layerType="software" on the host View.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="line">
    <stroke
        android:width="1dp"
        android:color="@color/border_light"
        android:dashWidth="3dp"
        android:dashGap="4dp" />
    <size android:height="1dp" />
</shape>
