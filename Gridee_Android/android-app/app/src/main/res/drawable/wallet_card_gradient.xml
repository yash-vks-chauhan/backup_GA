<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Minimal Professional Gradient: Deep Premium Black/Slate -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="135"
                android:startColor="#2A3236"
                android:centerColor="#161D22"
                android:endColor="#0B0F14"
                android:type="linear" />
            <corners android:radius="20dp" />
        </shape>
    </item>

    <!-- Bottom Darkener (placed below the grid now, to give the text area more contrast cleanly) -->
    <!-- Used to be a harsh #E6 covering everything -->
    <item>
        <shape>
            <gradient
                android:angle="90"
                android:startColor="#B3000000"
                android:centerColor="#40000000"
                android:endColor="#00000000"
                android:type="linear" />
            <corners android:radius="20dp" />
        </shape>
    </item>

    <!-- The Gold Pattern: Now sits ABOVE the darkener layer so it remains brilliant and sharp -->
    <item android:drawable="@drawable/bg_diamond_grid" />

    <!-- Glossy Metallic Sheen / Light Reflection (Under-glass effect) -->
    <!-- Remains nicely layered on top to give the gold a polished, embedded feel under glass -->
    <item bottom="40dp">
        <shape>
            <gradient
                android:angle="135"
                android:startColor="#25FFFFFF"
                android:centerColor="#00FFFFFF"
                android:endColor="#00FFFFFF"
                android:centerX="0.3"
                android:type="linear" />
            <corners android:radius="20dp" />
        </shape>
    </item>
</layer-list>
