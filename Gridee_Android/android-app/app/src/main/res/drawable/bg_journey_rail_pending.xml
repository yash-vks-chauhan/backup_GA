<?xml version="1.0" encoding="utf-8"?>
<!--
  Vertical gradient rail connecting check-in to check-out on the booking card.
  Amber at the top (live, "from here") fading toward muted at the bottom
  ("to here"). Reads as a journey with direction, not a static line.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <gradient
        android:angle="270"
        android:startColor="@color/status_text_pending"
        android:centerColor="#80D97706"
        android:endColor="#26D97706"
        android:type="linear" />
    <corners android:radius="2dp" />
</shape>
