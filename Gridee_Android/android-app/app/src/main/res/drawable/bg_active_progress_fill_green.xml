<?xml version="1.0" encoding="utf-8"?>
<!--
  Filled portion of the progress bar in normal state. Subtle gradient
  along the bar's length (darker green at the tail, brighter at the
  leading edge under the now-marker) so the bar reads as "energy moving
  toward the marker", not a flat slab.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <gradient
        android:angle="0"
        android:startColor="#34C759"
        android:endColor="@color/status_text_active"
        android:type="linear" />
    <corners android:radius="100dp" />
</shape>
