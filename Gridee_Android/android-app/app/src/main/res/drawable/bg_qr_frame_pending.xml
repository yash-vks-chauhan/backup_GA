<?xml version="1.0" encoding="utf-8"?>
<!--
  Soft tinted plate behind the QR with a hairline amber stroke. Anchors the
  QR as the card's primary action affordance ("scan me at entry") without
  competing with the timeline.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="#FFFBEB" />
    <stroke
        android:width="1dp"
        android:color="#26D97706" />
    <corners android:radius="16dp" />
</shape>
