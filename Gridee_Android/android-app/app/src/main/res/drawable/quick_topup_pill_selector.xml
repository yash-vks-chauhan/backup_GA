<?xml version="1.0" encoding="utf-8"?>
<!-- Floating white pill selector with subtle shadow for the quick top-up section -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Shadow layer (subtle, professional) -->
    <item
        android:left="1dp"
        android:top="1dp"
        android:right="1dp"
        android:bottom="0dp">
        <shape android:shape="rectangle">
            <solid android:color="#18000000" />
            <corners android:radius="24dp" />
        </shape>
    </item>
    <!-- Main white pill -->
    <item
        android:left="0dp"
        android:top="0dp"
        android:right="0dp"
        android:bottom="1dp">
        <shape android:shape="rectangle">
            <solid android:color="#FFFFFF" />
            <corners android:radius="24dp" />
        </shape>
    </item>
</layer-list>
