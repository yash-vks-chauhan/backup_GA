<?xml version="1.0" encoding="utf-8"?>
<!--
  Soft chip backing the vehicle plate in the hero footer. Treats the plate
  as a small badge of identity rather than free-floating text — gives the
  footer a clean two-pill layout (plate · amount).
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="@color/background_primary" />
    <stroke
        android:width="1dp"
        android:color="@color/border_light" />
    <corners android:radius="100dp" />
</shape>
