<?xml version="1.0" encoding="utf-8"?>
<!--
  Refined LIVE pill background. Slightly more saturated mint than the
  generic status_soft_active and a hairline border to lift it off the
  card surface — small but it matters at this size.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="#ECFDF5" />
    <stroke
        android:width="1dp"
        android:color="#3334C759" />
    <corners android:radius="100dp" />
</shape>
