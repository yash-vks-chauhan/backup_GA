<?xml version="1.0" encoding="utf-8"?>
<!--
  Solid white core sitting at the leading edge of the progress fill —
  the literal "you are here" bead on the timeline. Stays white across
  fill states (green / amber / red) so the eye always finds it; the halo
  underneath carries the colour signal.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="oval">
    <solid android:color="@android:color/white" />
    <stroke
        android:width="2dp"
        android:color="@color/status_text_active" />
    <size
        android:width="12dp"
        android:height="12dp" />
</shape>
